@model IEnumerable<eAdmin.Web.ViewModels.NotificationViewModel>
@{ ViewData["Title"] = "Notifications"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="fas fa-bell me-2 text-warning"></i>Notifications</h4>
    <form method="post" action="/Notification/MarkAllRead">@Html.AntiForgeryToken()
    <button class="btn btn-outline-secondary btn-sm"><i class="fas fa-check-double me-1"></i>Mark All Read</button></form>
</div>
@if(!Model.Any()){<div class="alert alert-info">No notifications.</div>}
<div class="list-group">
@foreach(var n in Model){
<div class="list-group-item list-group-item-action @(!n.IsRead?"list-group-item-light fw-bold":"")">
<div class="d-flex justify-content-between align-items-start">
<div>
<span class="badge @(n.NotificationType=="SMS"?"bg-success":"bg-primary") me-2">@n.NotificationType</span>
<span>@n.Subject</span>
</div>
<div class="d-flex gap-2 align-items-center">
<small class="text-muted">@n.CreatedAt.ToString("dd/MM HH:mm")</small>
@if(!n.IsRead){<form method="post" action="/Notification/MarkRead/@n.NotificationId">@Html.AntiForgeryToken()
<button class="btn btn-sm btn-outline-primary py-0 px-1"><i class="fas fa-check"></i></button></form>}
</div>
</div>
<p class="mb-0 small text-muted mt-1">@n.Message</p>
</div>}
</div>
