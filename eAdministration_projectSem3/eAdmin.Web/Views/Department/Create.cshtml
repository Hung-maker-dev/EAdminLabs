@model eAdmin.Web.ViewModels.DepartmentViewModel
@{
    ViewData["Title"] = "Create Department";
}

<h4><i class="fas fa-plus me-2 text-primary"></i>Create Department</h4>

<div class="card shadow-sm" style="max-width:500px">
    <div class="card-body">

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <strong>Please fix the errors below:</strong>
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <div class="mb-3">
                <label asp-for="DepartmentName" class="form-label fw-semibold"></label>
                <input asp-for="DepartmentName" class="form-control" />
                <!-- ✅ lỗi riêng field -->
                <span asp-validation-for="DepartmentName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Code" class="form-label fw-semibold">Code</label>
                <input asp-for="Code" class="form-control" placeholder="e.g. CS, IT" />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="HodUserId" class="form-label fw-semibold">HOD</label>
                <select asp-for="HodUserId" asp-items="ViewBag.HodList" class="form-select">
                    <option value="">-- Select HOD --</option>
                </select>
                <span asp-validation-for="HodUserId" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 justify-content-end">
                <a href="/Department/Index" class="btn btn-secondary">Cancel</a>
                <button class="btn btn-primary">Create</button>
            </div>

        </form>
    </div>
</div>

