@model IEnumerable<eAdmin.Web.ViewModels.DepartmentViewModel>
@{ ViewData["Title"] = "Manage Departments"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="fas fa-building me-2 text-primary"></i>Manage Departments</h4>
    <a href="/Department/Create" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>New Department</a>
</div>
@if(TempData["Success"]!=null){<div class="alert alert-success">@TempData["Success"]</div>}
@if(TempData["Error"]!=null){<div class="alert alert-danger">@TempData["Error"]</div>}
<table class="table table-hover table-bordered">
<thead class="table-dark"><tr><th>#</th><th>Name</th><th>Code</th><th>HOD</th><th>Users</th><th>Actions</th></tr></thead>
<tbody>@foreach(var d in Model){<tr>
<td>@d.DepartmentId</td><td><strong>@d.DepartmentName</strong></td><td>@d.Code</td>
<td>@d.HodName</td><td><span class="badge bg-info">@d.UserCount</span></td>
<td>
<a href="/Department/Edit/@d.DepartmentId" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
<form method="post" action="/Department/Delete/@d.DepartmentId" class="d-inline">@Html.AntiForgeryToken()
<button class="btn btn-danger btn-sm" onclick="return confirm('Delete?')"><i class="fas fa-trash"></i></button></form>
</td></tr>}</tbody></table>
