@model eAdmin.Web.ViewModels.SoftwareViewModel
@{
    ViewData["Title"] = "Edit Software";
}

<h4>
    <i class="fas fa-compact-disc me-2 text-primary"></i>
    Edit Software
</h4>

<div class="card shadow-sm">
    <div class="card-body">

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <strong>Please fix the following errors:</strong>
                    <ul class="mb-0 mt-1">
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@err.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <input type="hidden" asp-for="SoftwareId" />

            <div class="row g-3">

                <div class="col-md-6">
                    <label asp-for="SoftwareName" class="form-label fw-semibold"></label>
                    <input asp-for="SoftwareName" class="form-control" />
                    <span asp-validation-for="SoftwareName" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="Version" class="form-label fw-semibold"></label>
                    <input asp-for="Version" class="form-control" />
                    <span asp-validation-for="Version" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="LicenseExpiry" class="form-label fw-semibold">License Expiry</label>
                    <input asp-for="LicenseExpiry" type="date" class="form-control" />
                    <span asp-validation-for="LicenseExpiry" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="LicenseKey" class="form-label fw-semibold"></label>
                    <input asp-for="LicenseKey" class="form-control" />
                    <span asp-validation-for="LicenseKey" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="InstallGuideUrl" class="form-label fw-semibold">Install Guide URL</label>
                    <input asp-for="InstallGuideUrl" class="form-control" placeholder="https://..." />
                    <span asp-validation-for="InstallGuideUrl" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="LabId" class="form-label fw-semibold">
                        Lab (blank = all labs)
                    </label>
                    <select asp-for="LabId" asp-items="ViewBag.Labs" class="form-select">
                        <option value="">All Labs</option>
                    </select>
                    <span asp-validation-for="LabId" class="text-danger"></span>
                </div>

            </div>

            <div class="d-flex gap-2 justify-content-end mt-3">
                <a href="/Software/Index" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i> Save
                </button>
            </div>

        </form>
    </div>
</div>