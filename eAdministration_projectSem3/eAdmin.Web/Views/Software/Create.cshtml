@model eAdmin.Web.ViewModels.SoftwareViewModel
@{ ViewData["Title"] = "Create Software"; }
<h4><i class="fas fa-compact-disc me-2 text-primary"></i>Create Software</h4>
<div class="card shadow-sm"><div class="card-body">
<form asp-action="Create" method="post">@Html.AntiForgeryToken()
<input type="hidden" asp-for="SoftwareId"/>
<div class="row g-3">
<div class="col-md-6"><label asp-for="SoftwareName" class="form-label fw-semibold"></label><input asp-for="SoftwareName" class="form-control"/></div>
<div class="col-md-3"><label asp-for="Version" class="form-label fw-semibold"></label><input asp-for="Version" class="form-control"/></div>
<div class="col-md-3"><label asp-for="LicenseExpiry" class="form-label fw-semibold">License Expiry</label><input asp-for="LicenseExpiry" type="date" class="form-control"/></div>
<div class="col-md-6"><label asp-for="LicenseKey" class="form-label fw-semibold"></label><input asp-for="LicenseKey" class="form-control"/></div>
<div class="col-md-6"><label asp-for="InstallGuideUrl" class="form-label fw-semibold">Install Guide URL</label><input asp-for="InstallGuideUrl" class="form-control" placeholder="https://..."/></div>
<div class="col-md-6"><label asp-for="LabId" class="form-label fw-semibold">Lab (blank = all labs)</label><select asp-for="LabId" asp-items="ViewBag.Labs" class="form-select"><option value="">All Labs</option></select></div>
</div>
<div class="d-flex gap-2 justify-content-end mt-3"><a href="/Software/Index" class="btn btn-secondary">Cancel</a><button class="btn btn-primary">Save</button></div>
</form></div></div>
