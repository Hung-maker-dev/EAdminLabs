@model IEnumerable<eAdmin.Domain.Entities.ExtraLabRequest>
@{ ViewData["Title"] = "Extra Lab Requests"; }
<h4><i class="fas fa-plus-circle me-2 text-info"></i>Extra Lab Requests</h4>
@if(TempData["Success"]!=null){<div class="alert alert-success">@TempData["Success"]</div>}
<table class="table table-hover table-bordered">
<thead class="table-dark"><tr><th>#</th><th>Requester</th><th>Lab</th><th>Date</th><th>Time</th><th>Purpose</th><th>Status</th><th>Actions</th></tr></thead>
<tbody>@foreach(var r in Model){<tr>
<td>@r.RequestId</td><td>@r.RequestedBy</td><td>@r.LabId</td>
<td>@r.RequestDate.ToString("dd/MM/yyyy")</td>
<td>@r.StartTime.ToString(@"hh\:mm") – @r.EndTime.ToString(@"hh\:mm")</td>
<td class="small">@r.Purpose</td>
<td><span class="badge @(r.Status=="Approved"?"bg-success":r.Status=="Rejected"?"bg-danger":"bg-warning text-dark")">@r.Status</span></td>
<td>@if(r.Status=="Pending"){
<form method="post" action="/Lab/ReplyRequest/@r.RequestId" class="d-flex gap-1">@Html.AntiForgeryToken()
<input type="hidden" name="id" value="@r.RequestId"/>
<input name="reply" class="form-control form-control-sm" placeholder="Reply..." style="width:140px"/>
<button name="status" value="Approved" class="btn btn-success btn-sm">Approve</button>
<button name="status" value="Rejected" class="btn btn-danger btn-sm">Reject</button>
</form>}else{<small class="text-muted">@r.AdminReply</small>}</td>
</tr>}</tbody></table>
