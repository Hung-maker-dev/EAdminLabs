@model IEnumerable<eAdmin.Domain.Entities.ExtraLabRequest>
@{
    ViewData["Title"] = "Extra Lab Requests";
}

<style>
    .elr-wrap {
        padding: 1.5rem 0;
    }

    .elr-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
    }

    .elr-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--bs-body-color);
        margin: 0;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .elr-title i {
            color: #0dcaf0;
        }

    .elr-count {
        font-size: .78rem;
        font-weight: 500;
        background: rgba(13,202,240,.12);
        color: #0dcaf0;
        padding: .25rem .75rem;
        border-radius: 20px;
    }

    .elr-card {
        background: var(--bs-body-bg);
        border: 1px solid var(--bs-border-color);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,.06);
    }

    .elr-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .875rem;
    }

        .elr-table thead {
            background: rgba(13,202,240,.07);
        }

            .elr-table thead th {
                padding: .85rem 1rem;
                font-weight: 600;
                font-size: .78rem;
                text-transform: uppercase;
                letter-spacing: .05em;
                color: var(--bs-secondary-color);
                border-bottom: 1px solid var(--bs-border-color);
                white-space: nowrap;
            }

        .elr-table tbody tr {
            border-bottom: 1px solid var(--bs-border-color);
            transition: background .15s;
        }

            .elr-table tbody tr:last-child {
                border-bottom: none;
            }

            .elr-table tbody tr:hover {
                background: rgba(0,0,0,.02);
            }

        .elr-table td {
            padding: .85rem 1rem;
            vertical-align: middle;
        }

    .time-badge {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        background: rgba(13,202,240,.1);
        color: #087990;
        font-size: .8rem;
        font-weight: 500;
        padding: .2rem .65rem;
        border-radius: 20px;
    }

    .dark .time-badge {
        color: #0dcaf0;
        background: rgba(13,202,240,.15);
    }

    .status-badge {
        display: inline-block;
        font-size: .75rem;
        font-weight: 600;
        padding: .25rem .75rem;
        border-radius: 20px;
    }

    .status-approved {
        background: rgba(25,135,84,.12);
        color: #0a6640;
    }

    .status-rejected {
        background: rgba(220,53,69,.12);
        color: #a02030;
    }

    .status-pending {
        background: rgba(255,193,7,.15);
        color: #7d5a00;
    }

    [data-bs-theme="dark"] .status-approved {
        color: #5ef0a0;
        background: rgba(25,135,84,.25);
    }

    [data-bs-theme="dark"] .status-rejected {
        color: #ff8a95;
        background: rgba(220,53,69,.25);
    }

    [data-bs-theme="dark"] .status-pending {
        color: #ffd55a;
        background: rgba(255,193,7,.2);
    }

    .purpose-text {
        max-width: 200px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        color: var(--bs-secondary-color);
        line-height: 1.45;
    }

    .inline-form {
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .reply-input {
        font-size: .8rem !important;
        height: 34px !important;
        width: 150px !important;
        border-radius: 8px !important;
        background: var(--bs-body-bg) !important;
    }

    .btn-approve {
        font-size: .78rem;
        padding: .3rem .75rem;
        border-radius: 8px;
        background: rgba(25,135,84,.1);
        border: 1px solid rgba(25,135,84,.3);
        color: #0a6640;
        font-weight: 500;
        transition: all .15s;
    }

        .btn-approve:hover {
            background: #198754;
            color: #fff;
            border-color: #198754;
        }

    .btn-reject {
        font-size: .78rem;
        padding: .3rem .75rem;
        border-radius: 8px;
        background: rgba(220,53,69,.1);
        border: 1px solid rgba(220,53,69,.3);
        color: #a02030;
        font-weight: 500;
        transition: all .15s;
    }

        .btn-reject:hover {
            background: #dc3545;
            color: #fff;
            border-color: #dc3545;
        }

    [data-bs-theme="dark"] .btn-approve {
        color: #5ef0a0;
    }

    [data-bs-theme="dark"] .btn-reject {
        color: #ff8a95;
    }

    .replied-text {
        font-size: .8rem;
        color: var(--bs-secondary-color);
        font-style: italic;
    }

    .no-data {
        text-align: center;
        padding: 3rem;
        color: var(--bs-secondary-color);
    }

        .no-data i {
            font-size: 2.5rem;
            margin-bottom: .75rem;
            display: block;
            color: rgba(0,0,0,.15);
        }

    .req-id {
        font-size: .78rem;
        color: var(--bs-secondary-color);
        font-family: monospace;
    }

    .user-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: rgba(13,202,240,.15);
        color: #087990;
        font-size: .75rem;
        font-weight: 600;
    }
</style>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
        <i class="fas fa-check-circle"></i>
        <span>@TempData["Success"]</span>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

<div class="elr-wrap">
    <div class="elr-header">
        <h4 class="elr-title">
            <i class="fas fa-plus-circle"></i>
            Extra Lab Requests
        </h4>
        <span class="elr-count">@Model.Count() requests</span>
    </div>

    <div class="elr-card">
        @if (!Model.Any())
        {
            <div class="no-data">
                <i class="fas fa-inbox"></i>
                No extra lab requests yet.
            </div>
        }
        else
        {
            <table class="elr-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Requester</th>
                        <th>Lab</th>
                        <th>Date</th>
                        <th>Time Slot</th>
                        <th>Purpose</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td><span class="req-id">#@r.RequestId</span></td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="user-pill">@r.RequestedBy</span>
                                </div>
                            </td>
                            <td><strong>@r.LabId</strong></td>
                            <td style="white-space:nowrap">@r.RequestDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="time-badge">
                                    <i class="fas fa-clock" style="font-size:.7rem"></i>
                                    @r.StartTime.ToString(@"hh\:mm") – @r.EndTime.ToString(@"hh\:mm")
                                </span>
                            </td>
                            <td><div class="purpose-text">@r.Purpose</div></td>
                            <td>
                                <span class="status-badge status-@r.Status.ToLower()">
                                    @if (r.Status == "Approved")
                                    {
                                        <text><i class="fas fa-check me-1" style="font-size:.65rem"></i></text>
                                    }
                                    else if (r.Status == "Rejected")
                                    {

                                        <text><i class="fas fa-times me-1" style="font-size:.65rem"></i></text>
                                    }
                                    else
                                    {

                                        <text><i class="fas fa-clock me-1" style="font-size:.65rem"></i></text>
                                    }
                                    @r.Status
                                </span>
                            </td>
                            <td>
                                @if (r.Status == "Pending")
                                {
                                    <form method="post" action="/Lab/ReplyRequest/@r.RequestId" class="inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@r.RequestId" />
                                        <input name="reply" class="form-control reply-input" placeholder="Note (optional)..." />
                                        <button name="status" value="Approved" type="submit" class="btn-approve">
                                            <i class="fas fa-check me-1"></i>Approve
                                        </button>
                                        <button name="status" value="Rejected" type="submit" class="btn-reject">
                                            <i class="fas fa-times me-1"></i>Reject
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="replied-text">
                                        @if (!string.IsNullOrEmpty(r.AdminReply))
                                        {
                                            <i class="fas fa-comment-dots me-1" style="font-size:.7rem"></i>
                                            @r.AdminReply
                                        }
                                        else
                                        {

                                            <text>—</text>
                                        }
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
