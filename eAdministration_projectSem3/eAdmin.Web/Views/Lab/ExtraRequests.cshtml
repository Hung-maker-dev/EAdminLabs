@model IEnumerable<eAdmin.Domain.Entities.ExtraLabRequest>
@{
    ViewData["Title"] = "Extra Lab Requests";
}

<style>
    .elr-wrap {
        padding: 1.5rem 0;
    }

    .elr-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
    }

    .elr-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--bs-body-color);
        margin: 0;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .elr-title i {
            color: #0dcaf0;
        }

    .elr-count {
        font-size: .78rem;
        font-weight: 500;
        background: rgba(13,202,240,.12);
        color: #0dcaf0;
        padding: .25rem .75rem;
        border-radius: 20px;
    }

    .elr-card {
        background: var(--bs-body-bg);
        border: 1px solid var(--bs-border-color);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,.06);
    }

    .elr-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .875rem;
    }

        .elr-table thead {
            background: rgba(13,202,240,.07);
        }

            .elr-table thead th {
                padding: .85rem 1rem;
                font-weight: 600;
                font-size: .78rem;
                text-transform: uppercase;
                letter-spacing: .05em;
                color: var(--bs-secondary-color);
                border-bottom: 1px solid var(--bs-border-color);
                white-space: nowrap;
            }

        .elr-table tbody tr {
            border-bottom: 1px solid var(--bs-border-color);
            transition: background .15s;
        }

            .elr-table tbody tr:last-child {
                border-bottom: none;
            }

            .elr-table tbody tr:hover {
                background: rgba(0,0,0,.02);
            }

        .elr-table td {
            padding: .85rem 1rem;
            vertical-align: middle;
        }

    .time-badge {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        background: rgba(13,202,240,.1);
        color: #087990;
        font-size: .8rem;
        font-weight: 500;
        padding: .2rem .65rem;
        border-radius: 20px;
    }

    .dark .time-badge {
        color: #0dcaf0;
        background: rgba(13,202,240,.15);
    }

    .status-badge {
        display: inline-block;
        font-size: .75rem;
        font-weight: 600;
        padding: .25rem .75rem;
        border-radius: 20px;
    }

    .status-approved {
        background: rgba(25,135,84,.12);
        color: #0a6640;
    }

    .status-rejected {
        background: rgba(220,53,69,.12);
        color: #a02030;
    }

    .status-pending {
        background: rgba(255,193,7,.15);
        color: #7d5a00;
    }

    [data-bs-theme="dark"] .status-approved {
        color: #5ef0a0;
        background: rgba(25,135,84,.25);
    }

    [data-bs-theme="dark"] .status-rejected {
        color: #ff8a95;
        background: rgba(220,53,69,.25);
    }

    [data-bs-theme="dark"] .status-pending {
        color: #ffd55a;
        background: rgba(255,193,7,.2);
    }

    .purpose-text {
        max-width: 200px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        color: var(--bs-secondary-color);
        line-height: 1.45;
    }

    .inline-form {
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .reply-input {
        font-size: .8rem !important;
        height: 34px !important;
        width: 150px !important;
        border-radius: 8px !important;
        background: var(--bs-body-bg) !important;
    }

    .btn-approve {
        font-size: .78rem;
        padding: .3rem .75rem;
        border-radius: 8px;
        background: rgba(25,135,84,.1);
        border: 1px solid rgba(25,135,84,.3);
        color: #0a6640;
        font-weight: 500;
        transition: all .15s;
    }

        .btn-approve:hover {
            background: #198754;
            color: #fff;
            border-color: #198754;
        }

    .btn-reject {
        font-size: .78rem;
        padding: .3rem .75rem;
        border-radius: 8px;
        background: rgba(220,53,69,.1);
        border: 1px solid rgba(220,53,69,.3);
        color: #a02030;
        font-weight: 500;
        transition: all .15s;
    }

        .btn-reject:hover {
            background: #dc3545;
            color: #fff;
            border-color: #dc3545;
        }

    [data-bs-theme="dark"] .btn-approve {
        color: #5ef0a0;
    }

    [data-bs-theme="dark"] .btn-reject {
        color: #ff8a95;
    }

    .replied-text {
        font-size: .8rem;
        color: var(--bs-secondary-color);
        font-style: italic;
    }

    .no-data {
        text-align: center;
        padding: 3rem;
        color: var(--bs-secondary-color);
    }

        .no-data i {
            font-size: 2.5rem;
            margin-bottom: .75rem;
            display: block;
            color: rgba(0,0,0,.15);
        }

    .req-id {
        font-size: .78rem;
        color: var(--bs-secondary-color);
        font-family: monospace;
    }

    .user-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: rgba(13,202,240,.15);
        color: #087990;
        font-size: .75rem;
        font-weight: 600;
    }

    .status-expired {
        background: rgba(108,117,125,.12);
        color: #495057;
    }

    [data-bs-theme="dark"] .status-expired {
        color: #adb5bd;
        background: rgba(108,117,125,.25);
    }

    .expired-note {
        font-size: .75rem;
        color: var(--bs-secondary-color);
        font-style: italic;
    }

    /* Conflict warning card */
    .conflict-card {
        border: 1.5px solid #ffc107;
        border-radius: 14px;
        background: #fffdf0;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.25rem;
        display: flex;
        gap: 1rem;
        align-items: flex-start;
        box-shadow: 0 2px 10px rgba(255,193,7,.15);
    }

    [data-bs-theme="dark"] .conflict-card {
        background: rgba(255,193,7,.07);
        border-color: rgba(255,193,7,.4);
    }

    .conflict-icon {
        font-size: 1.5rem;
        color: #f59e0b;
        flex-shrink: 0;
        margin-top: .1rem;
    }

    .conflict-body {
        flex: 1;
    }

    .conflict-title {
        font-size: .95rem;
        font-weight: 600;
        color: #7a5900;
        margin-bottom: .3rem;
    }

    [data-bs-theme="dark"] .conflict-title {
        color: #ffd55a;
    }

    .conflict-desc {
        font-size: .85rem;
        color: #5f6368;
        margin-bottom: .85rem;
        line-height: 1.5;
    }

    .conflict-actions {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
    }

    .btn-force-approve {
        font-size: .82rem;
        padding: .4rem 1rem;
        border-radius: 8px;
        background: #f59e0b;
        border: none;
        color: #fff;
        font-weight: 600;
        cursor: pointer;
        transition: all .15s;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }

        .btn-force-approve:hover {
            background: #d97706;
            transform: translateY(-1px);
        }

    .btn-cancel-conflict {
        font-size: .82rem;
        padding: .4rem 1rem;
        border-radius: 8px;
        background: transparent;
        border: 1px solid var(--bs-border-color);
        color: var(--bs-secondary-color);
        cursor: pointer;
        transition: all .15s;
    }

        .btn-cancel-conflict:hover {
            background: var(--bs-secondary-bg);
        }
</style>

@* Success alert *@
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-3" role="alert">
        <i class="fas fa-check-circle"></i>
        <span>@TempData["Success"]</span>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

@* Error alert *@
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-3" role="alert">
        <i class="fas fa-times-circle"></i>
        <span>@TempData["Error"]</span>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

@* Schedule conflict warning *@
@if (TempData["ConflictRequestId"] != null)
{
    var conflictId = TempData["ConflictRequestId"]!.ToString();
    var conflictReply = TempData["ConflictReply"]?.ToString() ?? "";
    var conflictStatus = TempData["ConflictStatus"]?.ToString() ?? "Approved";

    <div class="conflict-card" id="conflictCard">
        <div class="conflict-icon">
            <i class="fas fa-exclamation-triangle"></i>
        </div>
        <div class="conflict-body">
            <div class="conflict-title">Schedule conflict detected!</div>
            <div class="conflict-desc">
                This lab already has a <strong>regular schedule</strong> that overlaps with the requested time slot.
                If you proceed with approval, that schedule will be <strong>cancelled</strong> and
                the affected instructor will receive an automatic notification.
            </div>
            <div class="conflict-actions">
                <form method="post" action="/Lab/ReplyRequest/@conflictId" style="display:inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@conflictId" />
                    <input type="hidden" name="status" value="@conflictStatus" />
                    <input type="hidden" name="reply" value="@conflictReply" />
                    <input type="hidden" name="forceApprove" value="true" />
                    <button type="submit" class="btn-force-approve">
                        <i class="fas fa-check-double"></i>
                        Approve anyway &amp; Cancel old schedule
                    </button>
                </form>
                <button class="btn-cancel-conflict" onclick="document.getElementById('conflictCard').remove()">
                    <i class="fas fa-times me-1"></i>Dismiss
                </button>
            </div>
        </div>
    </div>
}

<div class="elr-wrap">
    <div class="elr-header">
        <h4 class="elr-title">
            <i class="fas fa-plus-circle"></i>
            Extra Lab Requests
        </h4>
        <span class="elr-count">@Model.Count() requests</span>
    </div>

    <div class="elr-card">
        @if (!Model.Any())
        {
            <div class="no-data">
                <i class="fas fa-inbox"></i>
                No extra lab requests yet.
            </div>
        }
        else
        {
            <table class="elr-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Requester</th>
                        <th>Lab</th>
                        <th>Date</th>
                        <th>Time Slot</th>
                        <th>Purpose</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        var isExpired = r.Status == "Pending" &&
                        DateTime.Now > r.RequestDate.Date.Add(r.EndTime);
                        <tr>
                            <td><span class="req-id">#@r.RequestId</span></td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="user-pill">@r.RequestedBy</span>
                                </div>
                            </td>
                            <td><strong>@r.LabId</strong></td>
                            <td style="white-space:nowrap">@r.RequestDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="time-badge">
                                    <i class="fas fa-clock" style="font-size:.7rem"></i>
                                    @r.StartTime.ToString(@"hh\:mm") – @r.EndTime.ToString(@"hh\:mm")
                                </span>
                            </td>
                            <td><div class="purpose-text">@r.Purpose</div></td>
                            <td>
                                @if (isExpired)
                                {
                                    <span class="status-badge status-expired">
                                        <i class="fas fa-ban me-1" style="font-size:.65rem"></i>
                                        Expired
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge status-@r.Status.ToLower()">
                                        @if (r.Status == "Approved")
                                        {
                                            <text><i class="fas fa-check me-1" style="font-size:.65rem"></i></text>
                                        }
                                        else if (r.Status == "Rejected")
                                        {
                                            <text><i class="fas fa-times me-1" style="font-size:.65rem"></i></text>
                                        }
                                        else
                                        {
                                            <text><i class="fas fa-clock me-1" style="font-size:.65rem"></i></text>
                                        }
                                        @r.Status
                                    </span>
                                }
                            </td>
                            <td>
                                @if (isExpired)
                                {
                                    <span class="expired-note">
                                        <i class="fas fa-history me-1" style="font-size:.7rem"></i>
                                        Expired — no action available
                                    </span>
                                }
                                else if (r.Status == "Pending")
                                {
                                    <form method="post" action="/Lab/ReplyRequest/@r.RequestId" class="inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@r.RequestId" />
                                        <input name="reply" class="form-control reply-input" placeholder="Note (optional)..." />
                                        <button name="status" value="Approved" type="submit" class="btn-approve">
                                            <i class="fas fa-check me-1"></i>Approve
                                        </button>
                                        <button name="status" value="Rejected" type="submit" class="btn-reject">
                                            <i class="fas fa-times me-1"></i>Reject
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="replied-text">
                                        @if (!string.IsNullOrEmpty(r.AdminReply))
                                        {
                                            <i class="fas fa-comment-dots me-1" style="font-size:.7rem"></i>
                                            @r.AdminReply
                                        }
                                        else
                                        {
                                            <text>—</text>
                                        }
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
