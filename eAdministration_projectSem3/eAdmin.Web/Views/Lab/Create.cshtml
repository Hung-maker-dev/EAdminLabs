@model eAdmin.Domain.Entities.Lab
@{
    ViewData["Title"] = "Create Lab";
}
<h4><i class="fas fa-plus me-2 text-primary"></i>Create Lab</h4>
<div asp-validation-summary="ModelOnly" class="alert alert-danger" style="max-width:500px"></div>
<div class="card shadow-sm" style="max-width:500px">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3"><label asp-for="LabName" class="form-label fw-semibold"></label><input asp-for="LabName" class="form-control" /><span asp-validation-for="LabName" class="text-danger small"></span></div>
            <div class="mb-3"><label asp-for="Location" class="form-label fw-semibold"></label><input asp-for="Location" class="form-control" /><span asp-validation-for="Location" class="text-danger small"></span></div>
            <div class="mb-3"><label asp-for="Capacity" class="form-label fw-semibold"></label><input asp-for="Capacity" type="number" class="form-control" /><span asp-validation-for="Capacity" class="text-danger small"></span></div>
            <div class="mb-3 form-check"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label">Active</label></div>
            <div class="d-flex gap-2 justify-content-end"><a href="/Lab/Index" class="btn btn-secondary">Cancel</a><button class="btn btn-primary">Create</button></div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
