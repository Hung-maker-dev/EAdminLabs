@model eAdmin.Domain.Entities.ExtraLabRequest
@{ ViewData["Title"] = "Request Extra Lab"; }
<h4><i class="fas fa-calendar-plus me-2 text-info"></i>Request Extra Lab</h4>
<div class="card shadow-sm" style="max-width:520px"><div class="card-body">
<form asp-action="RequestExtra" method="post">@Html.AntiForgeryToken()
<div class="mb-3"><label asp-for="LabId" class="form-label fw-semibold">Lab</label>
<select asp-for="LabId" asp-items="ViewBag.Labs" class="form-select"><option value="">-- Select Lab --</option></select></div>
<div class="mb-3"><label asp-for="RequestDate" class="form-label fw-semibold">Date</label><input asp-for="RequestDate" type="date" class="form-control"/></div>
<div class="row g-2 mb-3">
<div class="col"><label asp-for="StartTime" class="form-label fw-semibold">Start</label><input asp-for="StartTime" type="time" class="form-control"/></div>
<div class="col"><label asp-for="EndTime" class="form-label fw-semibold">End</label><input asp-for="EndTime" type="time" class="form-control"/></div>
</div>
<div class="mb-3"><label asp-for="Purpose" class="form-label fw-semibold">Purpose</label><textarea asp-for="Purpose" class="form-control" rows="3"></textarea></div>
<div class="d-flex gap-2 justify-content-end"><a href="/Dashboard/Index" class="btn btn-secondary">Cancel</a><button class="btn btn-info">Submit Request</button></div>
</form></div></div>
