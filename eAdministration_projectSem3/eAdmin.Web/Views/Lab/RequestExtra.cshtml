@model eAdmin.Domain.Entities.ExtraLabRequest
@{
    ViewData["Title"] = "Request Extra Lab";
}

<style>
    .req-wrap {
        padding: 1.5rem 0;
        display: flex;
        justify-content: center;
    }

    .req-card {
        width: 100%;
        max-width: 560px;
        background: var(--bs-body-bg);
        border: 1px solid var(--bs-border-color);
        border-radius: 18px;
        box-shadow: 0 4px 24px rgba(0,0,0,.07);
        overflow: hidden;
    }

    .req-card-header {
        padding: 1.25rem 1.5rem 1rem;
        border-bottom: 1px solid var(--bs-border-color);
        background: rgba(13,202,240,.05);
    }

        .req-card-header h4 {
            margin: 0;
            font-size: 1.05rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: .5rem;
            color: var(--bs-body-color);
        }

            .req-card-header h4 i {
                color: #0dcaf0;
            }

        .req-card-header p {
            margin: .25rem 0 0;
            font-size: .82rem;
            color: var(--bs-secondary-color);
        }

    .req-card-body {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.15rem;
    }

    .form-label {
        font-size: .82rem;
        font-weight: 600;
        color: var(--bs-secondary-color);
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: .4rem;
    }

    .slot-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .5rem;
    }

    .slot-option {
        display: none;
    }

    .slot-label {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        padding: .65rem .5rem;
        border-radius: 10px;
        border: 1.5px solid var(--bs-border-color);
        cursor: pointer;
        text-align: center;
        transition: all .18s;
        background: var(--bs-body-bg);
        user-select: none;
        position: relative;
    }

        .slot-label .slot-time {
            font-size: .9rem;
            font-weight: 600;
            color: var(--bs-body-color);
        }

        .slot-label .slot-period {
            font-size: .72rem;
            color: var(--bs-secondary-color);
            margin-top: .1rem;
        }

        .slot-label:hover {
            border-color: #0dcaf0;
            background: rgba(13,202,240,.05);
        }

        /* Checkmark badge top-right corner */
        .slot-label .slot-check {
            display: none;
            position: absolute;
            top: 6px;
            right: 8px;
            font-size: .65rem;
            color: #087990;
        }

    .slot-option:checked + .slot-label {
        border-color: #0dcaf0;
        background: rgba(13,202,240,.1);
    }

        .slot-option:checked + .slot-label .slot-time {
            color: #087990;
        }

        .slot-option:checked + .slot-label .slot-check {
            display: inline;
        }

    [data-bs-theme="dark"] .slot-option:checked + .slot-label .slot-time,
    [data-bs-theme="dark"] .slot-option:checked + .slot-label .slot-check {
        color: #0dcaf0;
    }

    .slot-wrapper.slot-past {
        display: none;
    }

    .slot-no-available {
        display: none;
        font-size: .82rem;
        color: #dc3545;
        padding: .5rem .75rem;
        background: rgba(220,53,69,.06);
        border-radius: 8px;
        border: 1px solid rgba(220,53,69,.15);
    }

    /* Preview of selected slots */
    .selected-slots-preview {
        display: none;
        margin-top: .5rem;
        font-size: .78rem;
        color: #087990;
        display: flex;
        flex-wrap: wrap;
        gap: .3rem;
    }

    .selected-slot-badge {
        background: rgba(13,202,240,.15);
        border: 1px solid rgba(13,202,240,.3);
        border-radius: 6px;
        padding: .15rem .5rem;
        font-weight: 600;
    }

    .req-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--bs-border-color);
        display: flex;
        justify-content: flex-end;
        gap: .6rem;
        background: rgba(0,0,0,.02);
    }

    .btn-cancel {
        font-size: .875rem;
        padding: .5rem 1.1rem;
        border-radius: 10px;
        background: transparent;
        border: 1px solid var(--bs-border-color);
        color: var(--bs-body-color);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        transition: all .15s;
    }

        .btn-cancel:hover {
            background: var(--bs-secondary-bg);
        }

    .btn-submit {
        font-size: .875rem;
        padding: .5rem 1.4rem;
        border-radius: 10px;
        background: #0dcaf0;
        border: none;
        color: #000;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        transition: all .15s;
        cursor: pointer;
    }

        .btn-submit:hover {
            background: #0aa8cc;
            transform: translateY(-1px);
        }

        .btn-submit:active {
            transform: translateY(0);
        }

    .error-msg {
        font-size: .78rem;
        color: #dc3545;
        margin-top: .25rem;
    }

    .slot-error {
        display: none;
        font-size: .78rem;
        color: #dc3545;
        margin-top: .3rem;
    }

    input[type="date"].form-control {
        font-size: .9rem;
    }

    textarea.form-control {
        font-size: .9rem;
        resize: none;
    }
</style>


<div class="req-wrap">
    <div class="req-card">
        <div class="req-card-header">
            <h4><i class="fas fa-calendar-plus"></i> Request Extra Lab Session</h4>
            <p>Submit a request for an additional lab booking outside regular schedule.</p>
        </div>

        <form asp-action="RequestExtra" method="post" id="reqForm">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="error-msg px-4 pt-3"></div>

            <div id="hiddenSlotsContainer"></div>

            <div class="req-card-body">

                <!-- Lab -->
                <div>
                    <label asp-for="LabId" class="form-label">Lab</label>
                    <select asp-for="LabId" asp-items="ViewBag.Labs"
                            class="form-select" style="border-radius:10px;" required>
                        <option value="">— Select a lab —</option>
                    </select>
                    <span asp-validation-for="LabId" class="error-msg"></span>
                </div>

                <!-- Date -->
                <div>
                    <label class="form-label" for="requestDate">Date</label>
                    <input type="date" asp-for="RequestDate" id="requestDate"
                           class="form-control" style="border-radius:10px;" required />
                    <span asp-validation-for="RequestDate" class="error-msg"></span>
                </div>

                <!-- Time Slots (multi-select via checkbox) -->
                <div>
                    <label class="form-label">
                        Time Slot
                        <span style="font-size:.72rem;font-weight:400;color:var(--bs-secondary-color);text-transform:none;letter-spacing:0;margin-left:.4rem;">
                            (you may select multiple)
                        </span>
                    </label>

                    <div class="slot-grid" id="slotGrid">

                        <div class="slot-wrapper" data-start="07:00" data-end="09:00">
                            <input type="checkbox" name="slot" value="07:00|09:00" class="slot-option" id="slot1" />
                            <label for="slot1" class="slot-label">
                                <i class="fas fa-check slot-check"></i>
                                <span class="slot-time">07:00 – 09:00</span>
                                <span class="slot-period">Morning</span>
                            </label>
                        </div>

                        <div class="slot-wrapper" data-start="09:00" data-end="11:00">
                            <input type="checkbox" name="slot" value="09:00|11:00" class="slot-option" id="slot2" />
                            <label for="slot2" class="slot-label">
                                <i class="fas fa-check slot-check"></i>
                                <span class="slot-time">09:00 – 11:00</span>
                                <span class="slot-period">Late Morning</span>
                            </label>
                        </div>

                        <div class="slot-wrapper" data-start="13:00" data-end="15:00">
                            <input type="checkbox" name="slot" value="13:00|15:00" class="slot-option" id="slot3" />
                            <label for="slot3" class="slot-label">
                                <i class="fas fa-check slot-check"></i>
                                <span class="slot-time">13:00 – 15:00</span>
                                <span class="slot-period">Afternoon</span>
                            </label>
                        </div>

                        <div class="slot-wrapper" data-start="15:00" data-end="17:00">
                            <input type="checkbox" name="slot" value="15:00|17:00" class="slot-option" id="slot4" />
                            <label for="slot4" class="slot-label">
                                <i class="fas fa-check slot-check"></i>
                                <span class="slot-time">15:00 – 17:00</span>
                                <span class="slot-period">Late Afternoon</span>
                            </label>
                        </div>

                        <div class="slot-wrapper" data-start="17:00" data-end="19:00">
                            <input type="checkbox" name="slot" value="17:00|19:00" class="slot-option" id="slot5" />
                            <label for="slot5" class="slot-label">
                                <i class="fas fa-check slot-check"></i>
                                <span class="slot-time">17:00 – 19:00</span>
                                <span class="slot-period">Evening</span>
                            </label>
                        </div>

                    </div>

                    <!-- Preview of selected slots -->
                    <div class="selected-slots-preview" id="selectedPreview"></div>

                    <div class="slot-no-available" id="slotNoAvailable">
                        <i class="fas fa-clock me-1"></i>
                        No available time slots for today. Please select a future date.
                    </div>
                    <div class="slot-error" id="slotError">Please select at least one time slot.</div>
                </div>

                <!-- Purpose -->
                <div>
                    <label asp-for="Purpose" class="form-label">Purpose</label>
                    <textarea asp-for="Purpose" class="form-control"
                              rows="3" minlength="5" required
                              style="border-radius:10px;"></textarea>
                    <span asp-validation-for="Purpose" class="error-msg"></span>
                </div>

            </div>

            <div class="req-footer">
                <a href="/Dashboard/Index" class="btn-cancel">Cancel</a>
                <button type="submit" class="btn-submit" id="btnSubmit">
                    <i class="fas fa-paper-plane"></i> Submit
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    // Hide past time slots when the selected date is today
    function filterSlotsByDate() {
        var dateInput    = document.getElementById('requestDate');
        var selectedDate = dateInput.value;
        var today        = new Date();
        var todayIso     = today.toISOString().split('T')[0];
        var isToday      = (selectedDate === todayIso);

        var currentTotal = today.getHours() * 60 + today.getMinutes();
        var wrappers     = document.querySelectorAll('.slot-wrapper');
        var anyVisible   = false;

        wrappers.forEach(function (wrapper) {
            var parts     = wrapper.getAttribute('data-start').split(':');
            var slotStart = parseInt(parts[0]) * 60 + parseInt(parts[1]);
            var isPast    = isToday && slotStart <= currentTotal;

            if (isPast) {
                wrapper.classList.add('slot-past');
                var cb = wrapper.querySelector('input[type="checkbox"]');
                if (cb) cb.checked = false;
            } else {
                wrapper.classList.remove('slot-past');
                anyVisible = true;
            }
        });

        updatePreview();

        var noAvailEl = document.getElementById('slotNoAvailable');
        var submitBtn = document.getElementById('btnSubmit');
        if (!anyVisible) {
            noAvailEl.style.display = 'block';
            submitBtn.disabled      = true;
            submitBtn.style.opacity = '.5';
            submitBtn.style.cursor  = 'not-allowed';
        } else {
            noAvailEl.style.display = 'none';
            submitBtn.disabled      = false;
            submitBtn.style.opacity = '1';
            submitBtn.style.cursor  = 'pointer';
        }
    }

    // Update selected-slot preview badges
    function updatePreview() {
        var preview = document.getElementById('selectedPreview');
        var checked = document.querySelectorAll('input[name="slot"]:checked');
        preview.innerHTML = '';

        if (checked.length === 0) {
            preview.style.display = 'none';
            return;
        }

        preview.style.display = 'flex';
        checked.forEach(function (cb) {
            var parts = cb.value.split('|');
            var badge = document.createElement('span');
            badge.className   = 'selected-slot-badge';
            badge.textContent = parts[0] + ' – ' + parts[1];
            preview.appendChild(badge);
        });
    }

    // Initialise: set today as default date and filter slots
    (function () {
        var d     = new Date();
        var today = d.toISOString().split('T')[0];
        var input = document.getElementById('requestDate');
        input.value = today;
        input.min   = today;
        filterSlotsByDate();
    })();

    // Re-filter slots on date change
    document.getElementById('requestDate').addEventListener('change', function () {
        filterSlotsByDate();
        document.getElementById('slotError').style.display = 'none';
    });

    // Update preview and hide error on checkbox change
    document.querySelectorAll('input[name="slot"]').forEach(function (cb) {
        cb.addEventListener('change', function () {
            updatePreview();
            document.getElementById('slotError').style.display = 'none';
        });
    });

    // Submit: validate slots then build hidden inputs for each selected slot
    document.getElementById('reqForm').addEventListener('submit', function (e) {
        var checked = document.querySelectorAll('input[name="slot"]:checked');

        if (checked.length === 0) {
            e.preventDefault();
            document.getElementById('slotError').style.display = 'block';
            return;
        }

        // Clear previous hidden inputs (in case of re-submit)
        var container = document.getElementById('hiddenSlotsContainer');
        container.innerHTML = '';

        // Build StartTimes[i] / EndTimes[i] hidden fields for each selected slot
        checked.forEach(function (cb, idx) {
            var parts = cb.value.split('|');

            var hStart = document.createElement('input');
            hStart.type  = 'hidden';
            hStart.name  = 'StartTimes[' + idx + ']';
            hStart.value = parts[0] + ':00';

            var hEnd = document.createElement('input');
            hEnd.type  = 'hidden';
            hEnd.name  = 'EndTimes[' + idx + ']';
            hEnd.value = parts[1] + ':00';

            container.appendChild(hStart);
            container.appendChild(hEnd);
        });
    });
</script>
