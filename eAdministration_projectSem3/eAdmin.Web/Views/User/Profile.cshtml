@model eAdmin.Web.ViewModels.UserViewModel
@{
    ViewData["Title"] = "My Profile";
}
<h4><i class="fas fa-user-circle me-2 text-primary"></i>My Profile</h4>
<div class="row g-3">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">Profile Info</div>
            <div class="card-body">
                <form asp-action="Profile" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="UserId" />
                    <div class="mb-3"><label class="form-label fw-semibold">Username</label><input value="@Model.Username" class="form-control" readonly /></div>
                    <div class="mb-3"><label asp-for="FullName" class="form-label fw-semibold"></label><input asp-for="FullName" class="form-control" /></div>
                    <div class="mb-3"><label asp-for="Email" class="form-label fw-semibold"></label><input asp-for="Email" class="form-control" /></div>
                    <div class="mb-3"><label asp-for="Phone" class="form-label fw-semibold"></label><input asp-for="Phone" class="form-control" /></div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Department</label>
                        <input value="@(string.IsNullOrEmpty(Model.DeptName) ? "Not assigned" : Model.DeptName)"
                               class="form-control" readonly />
                    </div>

                    <div class="mb-3 d-flex gap-2 align-items-center">
                        <span class="badge bg-secondary fs-6 px-3 py-2">
                            <i class="fas fa-shield-alt me-1"></i>@Model.RoleName
                        </span>
                        @if (!string.IsNullOrEmpty(Model.DeptName))
                        {
                            <span class="badge bg-info fs-6 px-3 py-2">
                                <i class="fas fa-building me-1"></i>@Model.DeptName
                            </span>
                        }
                    </div>

                    <button type="submit" class="btn btn-primary btn-sm">Update Profile</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-warning">Change Password</div>
            <div class="card-body">
                <form asp-controller="User" asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3"><label class="form-label fw-semibold">Current Password</label><input name="CurrentPassword" type="password" class="form-control" /></div>
                    <div class="mb-3"><label class="form-label fw-semibold">New Password</label><input name="NewPassword" type="password" class="form-control" /></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Confirm Password</label><input name="ConfirmPassword" type="password" class="form-control" /></div>
                    <button type="submit" class="btn btn-warning btn-sm">Change Password</button>
                </form>
            </div>
        </div>
    </div>
</div>