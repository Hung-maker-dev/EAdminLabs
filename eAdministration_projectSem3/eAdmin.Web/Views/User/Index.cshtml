@model IEnumerable<eAdmin.Web.ViewModels.UserViewModel>
@{ ViewData["Title"] = "Manage Users"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="fas fa-users me-2 text-primary"></i>Manage Users</h4>
    <a href="/User/Create" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>New User</a>
</div>
@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }
<form method="get" class="row g-2 mb-3">
    <div class="col-md-3"><select name="role" class="form-select form-select-sm"><option value="">All Roles</option>@foreach(var r in (IEnumerable<dynamic>)ViewBag.Roles){<option value="@r.RoleName" selected="@(ViewBag.FilterRole==r.RoleName)">@r.RoleName</option>}</select></div>
    <div class="col-md-3"><select name="deptId" class="form-select form-select-sm"><option value="">All Departments</option>@foreach(var d in (IEnumerable<dynamic>)ViewBag.Departments){<option value="@d.DepartmentId">@d.DepartmentName</option>}</select></div>
 


        <div class="col-md-3">
        <input type="text" name="search" value="@ViewBag.Search"
               class="form-control form-control-sm"
               placeholder="🔍 Search by name..." />
              
    </div>
    <div class="col-md-2"><button class="btn btn-outline-secondary btn-sm w-100"><i class="fas fa-filter me-1"></i>Filter</button></div>
</form>
<div class="table-responsive"><table class="table table-hover table-bordered align-middle">
<thead class="table-dark"><tr><th>#</th><th>Username</th><th>Full Name</th><th>Email</th><th>Role</th><th>Department</th><th>Status</th><th>Actions</th></tr></thead>
<tbody>@foreach(var u in Model){
<tr><td>@u.UserId</td><td><strong>@u.Username</strong></td><td>@u.FullName</td><td>@u.Email</td>
<td><span class="badge bg-secondary">@u.RoleName</span></td>
<td>@u.DeptName</td>
<td><span class="badge @(u.IsActive?"bg-success":"bg-danger")">@(u.IsActive?"Active":"Inactive")</span></td>
<td>
<a href="/User/Edit/@u.UserId" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
<form method="post" action="/User/ToggleActive/@u.UserId" class="d-inline">@Html.AntiForgeryToken()
<button class="btn btn-sm @(u.IsActive?"btn-outline-danger":"btn-outline-success")" onclick="return confirm('Toggle status?')"><i class="fas fa-@(u.IsActive?"ban":"check")"></i></button></form>
</td></tr>}</tbody></table></div>
