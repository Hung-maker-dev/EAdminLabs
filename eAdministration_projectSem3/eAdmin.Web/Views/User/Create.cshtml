@model eAdmin.Web.ViewModels.UserViewModel
@{ ViewData["Title"] = "Create User"; }
<h4><i class="fas fa-user-plus me-2 text-primary"></i>Create User</h4>
<div class="card shadow-sm"><div class="card-body">
<form asp-action="Create" method="post">
@Html.AntiForgeryToken()
<div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid?"none":"block")"></div>
<div class="row g-3">
<div class="col-md-6"><label asp-for="Username" class="form-label fw-semibold"></label><input asp-for="Username" class="form-control"/><span asp-validation-for="Username" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="FullName" class="form-label fw-semibold"></label><input asp-for="FullName" class="form-control"/></div>
<div class="col-md-6"><label asp-for="Email" class="form-label fw-semibold"></label><input asp-for="Email" class="form-control"/></div>
<div class="col-md-6"><label asp-for="Phone" class="form-label fw-semibold"></label><input asp-for="Phone" class="form-control"/></div>
<div class="col-md-6"><label asp-for="Password" class="form-label fw-semibold">Password</label><input asp-for="Password" type="password" class="form-control"/></div>
<div class="col-md-3"><label asp-for="RoleId" class="form-label fw-semibold">Role</label><select asp-for="RoleId" asp-items="ViewBag.Roles" class="form-select"><option value="">-- Select --</option></select></div>
<div class="col-md-3"><label asp-for="DepartmentId" class="form-label fw-semibold">Department</label><select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="form-select"><option value="">-- None --</option></select></div>
<div class="col-md-3 d-flex align-items-end"><div class="form-check"><input asp-for="IsActive" class="form-check-input"/><label asp-for="IsActive" class="form-check-label">Active</label></div></div>
</div>
<div class="d-flex justify-content-end gap-2 mt-3"><a href="/User/Index" class="btn btn-secondary">Cancel</a><button type="submit" class="btn btn-primary">Create</button></div>
</form></div></div>
