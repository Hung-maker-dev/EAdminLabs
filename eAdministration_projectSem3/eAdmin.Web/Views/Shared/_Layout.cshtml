<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - eAdmin Lab</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        var role = User.FindFirst("Role")?.Value ?? "";
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" href="/Dashboard/Index"><i class="fas fa-laptop-code me-2"></i>eAdmin Lab</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" href="/Dashboard/Index"><i class="fas fa-tachometer-alt me-1"></i>Dashboard</a></li>

                        @if (role == "Admin" || role == "HOD" || role == "Instructor" || role == "TechStaff")
                        {
                            <li class="nav-item"><a class="nav-link" href="/Complaint/Index"><i class="fas fa-exclamation-triangle me-1"></i>Complaints</a></li>
                        }

                        @if (role != "Student")
                        {
                            <li class="nav-item"><a class="nav-link" href="/Schedule/Index"><i class="fas fa-calendar-alt me-1"></i>Schedule</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Equipment/Index"><i class="fas fa-desktop me-1"></i>Equipment</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Software/Index"><i class="fas fa-compact-disc me-1"></i>Software</a></li>
                        }

                        <li class="nav-item"><a class="nav-link" href="/LearningMaterial/Index"><i class="fas fa-book-open me-1"></i>e-Learning</a></li>

                        @if (role == "HOD")
                        {
                            <li class="nav-item"><a class="nav-link" href="/Lab/RequestExtra"><i class="fas fa-plus-circle me-1"></i>Request Lab</a></li>
                        }

                        @if (role == "Admin" || role == "HOD")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="fas fa-chart-bar me-1"></i>Reports</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="/Report/Overview"><i class="fas fa-tachometer-alt me-2"></i>Overview</a></li>
                                    <li><a class="dropdown-item" href="/Report/Equipment"><i class="fas fa-desktop me-2"></i>Equipment Condition</a></li>
                                    <li><a class="dropdown-item" href="/Report/Complaints"><i class="fas fa-exclamation-circle me-2"></i>Complaints</a></li>
                                    @if (role == "Admin")
                                    {
                                        <li><a class="dropdown-item" href="/Report/SoftwareExpiry"><i class="fas fa-clock me-2"></i>Software Expiry</a></li>
                                    }
                                </ul>
                            </li>
                        }

                        @if (role == "Admin")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="fas fa-cog me-1"></i>Admin</a>
                                <ul class="dropdown-menu">
                                    <li><h6 class="dropdown-header">Users & Access</h6></li>
                                    <li><a class="dropdown-item" href="/User/Index"><i class="fas fa-users me-2"></i>Users</a></li>
                                    <li><a class="dropdown-item" href="/Role/Index"><i class="fas fa-shield-alt me-2"></i>Roles</a></li>
                                    <li><a class="dropdown-item" href="/Department/Index"><i class="fas fa-building me-2"></i>Departments</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><h6 class="dropdown-header">Lab Management</h6></li>
                                    <li><a class="dropdown-item" href="/Lab/Index"><i class="fas fa-door-open me-2"></i>Labs</a></li>
                                    <li><a class="dropdown-item" href="/Lab/ExtraRequests"><i class="fas fa-clipboard-list me-2"></i>Extra Requests</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><h6 class="dropdown-header">Equipment</h6></li>
                                    <li><a class="dropdown-item" href="/EquipmentType/Index"><i class="fas fa-tags me-2"></i>Equipment Types</a></li>
                                    <li><a class="dropdown-item" href="/ComplaintType/Index"><i class="fas fa-list me-2"></i>Complaint Types</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><h6 class="dropdown-header">System</h6></li>
                                    <li><a class="dropdown-item" href="/AuditLog/Index"><i class="fas fa-history me-2"></i>Audit Log</a></li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        <!-- Bell notification icon -->
                        <li class="nav-item dropdown me-2">
                            <a class="nav-link position-relative" href="#" id="bellDropdown" data-bs-toggle="dropdown">
                                <i class="fas fa-bell fa-lg"></i>
                                <span id="notif-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display:none;font-size:0.6rem"></span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow" style="width:320px;max-height:400px;overflow-y:auto" id="bellMenu">
                                <li><h6 class="dropdown-header d-flex justify-content-between">Notifications <a href="/Notification/Index" class="small">View all</a></h6></li>
                                <div id="bell-items">
                                <li><span class="dropdown-item text-muted small">Loading...</span></li>
                </div>
                <li><hr class="dropdown-divider" /></li>
                <li><a class="dropdown-item text-center small" href="/Notification/Index"><i class="fas fa-list me-1"></i>All Notifications</a></li>
                </ul>
                </li>

                <!-- User menu -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        <i class="fas fa-user-circle me-1"></i>@User.Identity!.Name
                        <span class="badge bg-warning text-dark ms-1">@role</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/User/Profile"><i class="fas fa-id-card me-2"></i>My Profile</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger"><i class="fas fa-sign-out-alt me-2"></i>Logout</button>
                            </form>
                        </li>
                    </ul>
                </li>
                </ul>
            </div>
            </div>
        </nav>
    }

    <div class="container-fluid py-3">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show"><i class="fas fa-check-circle me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show"><i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
            async function loadBell() {
                try {
                    const r = await fetch('/Notification/UnreadCount');
                    const d = await r.json();
                    const badge = document.getElementById('notif-badge');
                    if (d.count > 0) { badge.textContent = d.count; badge.style.display=''; }
                    else { badge.style.display='none'; }
                } catch(e) {}
            }
            async function loadBellItems() {
                try {
                    const r = await fetch('/Notification/Latest');
                    const items = await r.json();
                    const container = document.getElementById('bell-items');
                    if (!items.length) { container.innerHTML='<li><span class="dropdown-item text-muted small">No notifications</span></li>'; return; }
                    container.innerHTML = items.map(n =>
                        `<li><a class="dropdown-item small ${n.isRead?'':'fw-bold'}" href="/Notification/Index">
                        <span class="badge ${n.notificationType==='SMS'?'bg-success':'bg-primary'} me-1">${n.notificationType}</span>
                        ${n.subject}<br/><span class="text-muted" style="font-size:0.75rem">${n.createdAt}</span></a></li>`
                    ).join('');
                } catch(e) {}
            }
            loadBell();
            document.getElementById('bellDropdown')?.addEventListener('click', loadBellItems);
            setInterval(loadBell, 30000);
        </script>
    }


    @RenderSection("Scripts", required: false)

</body>
</html>