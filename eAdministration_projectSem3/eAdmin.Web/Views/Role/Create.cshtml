@model eAdmin.Web.ViewModels.RoleViewModel
@{ ViewData["Title"] = "Create Role"; }
<h4><i class="fas fa-plus me-2 text-primary"></i>Create Role</h4>
<div class="card shadow-sm" style="max-width:500px"><div class="card-body">
<form asp-action="Create" method="post">@Html.AntiForgeryToken()
<div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid?"none":"block")"></div>
<div class="mb-3"><label asp-for="RoleName" class="form-label fw-semibold"></label><input asp-for="RoleName" class="form-control"/></div>
<div class="mb-3"><label asp-for="Description" class="form-label fw-semibold"></label><input asp-for="Description" class="form-control"/></div>
<div class="d-flex gap-2 justify-content-end"><a href="/Role/Index" class="btn btn-secondary">Cancel</a><button class="btn btn-primary">Create</button></div>
</form></div></div>
