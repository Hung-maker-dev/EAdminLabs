@model eAdmin.Web.ViewModels.ComplaintTypeViewModel
@{
    ViewData["Title"] = "Create Complaint Type";
}

<div class="d-flex align-items-center mb-3">
    <a href="/ComplaintType/Index" class="btn btn-outline-secondary btn-sm me-2">
        <i class="fas fa-arrow-left"></i>
    </a>
    <h4 class="mb-0"><i class="fas fa-plus me-2 text-primary"></i>Create Complaint Type</h4>
</div>

<div class="card shadow-sm" style="max-width:520px">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            @* Show ALL model errors prominently *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    <strong>Please fix the following errors:</strong>
                    <ul class="mb-0 mt-1">
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@err.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <div class="mb-3">
                <label asp-for="TypeName" class="form-label fw-semibold">
                    Type Name <span class="text-danger">*</span>
                </label>
                <input asp-for="TypeName" class="form-control @(!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey("TypeName") ? "is-invalid" : "")"
                       placeholder="e.g. Hardware Failure, Software Issue, Network Problem"
                       autofocus />
                <span asp-validation-for="TypeName" class="invalid-feedback"></span>
                <div class="form-text">Must be unique. Min 2 characters.</div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold">
                    Description <small class="text-muted fw-normal">(optional)</small>
                </label>
                <textarea asp-for="Description" class="form-control" rows="3"
                          placeholder="Brief description of this complaint type..."></textarea>
            </div>

            <div class="d-flex gap-2 justify-content-end">
                <a href="/ComplaintType/Index" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i>Create
                </button>
            </div>

        </form>
    </div>
</div>
