@model IEnumerable<eAdmin.Web.ViewModels.ComplaintListViewModel>
@{
    ViewData["Title"] = "Complaints";
    var role = User.FindFirst("Role")?.Value ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="fas fa-exclamation-triangle me-2 text-danger"></i>Complaints</h4>
    @if (role == "Instructor" || role == "TechStaff" || role == "Student")
    {
        <a href="/Complaint/Create" class="btn btn-danger btn-sm">
            <i class="fas fa-plus me-1"></i>Submit Complaint
        </a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle me-2"></i>No complaints found.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle" style="font-size:0.9rem">
            <thead class="table-dark">
                <tr>
                    <th style="width:45px">#</th>
                    <th>Title</th>
                    <th style="width:110px">Type</th>
                    <th style="width:100px">Lab</th>
                    <th style="width:90px">Priority</th>
                    <th style="width:100px">Status</th>
                    <th style="width:130px">Reporter</th>
                    <th style="width:130px">Assignee</th>
                    <th style="width:80px">Created</th>
                    <th style="width:80px">Resolved</th>
                    <th style="width:60px">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    var pb = c.Priority switch
                    {
                        "Critical" => "bg-danger",
                        "High" => "bg-warning text-dark",
                        "Medium" => "bg-info text-dark",
                        _ => "bg-secondary"
                    };
                    var sb = c.Status switch
                    {
                        "Pending" => "bg-secondary",
                        "Assigned" => "bg-info text-dark",
                        "InProgress" => "bg-warning text-dark",
                        "Resolved" => "bg-success",
                        "Closed" => "bg-dark",
                        _ => "bg-secondary"
                    };
                    var rowHighlight = c.Priority == "Critical" ? "table-danger" :
                    c.Priority == "High" ? "table-warning" : "";
                    <tr class="@rowHighlight">
                        <td class="text-muted small">@c.ComplaintId</td>
                        <td>
                            <a href="/Complaint/Details/@c.ComplaintId" class="text-decoration-none fw-semibold">
                                @c.Title
                            </a>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(c.TypeName))
                            {
                                <span class="badge bg-light text-dark border">@c.TypeName</span>
                            }
                            else
                            {

                                <span class="text-muted">–</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(c.LabName))
                            {
                                <span class="small">@c.LabName</span>
                            }
                            else
                            {

                                <span class="text-muted">–</span>
                            }
                        </td>
                        <td><span class="badge @pb">@c.Priority</span></td>
                        <td><span class="badge @sb">@c.Status</span></td>
                        <td>
                            @if (!string.IsNullOrEmpty(c.ReporterName))
                            {
                                <span class="small"><i class="fas fa-user me-1 text-muted"></i>@c.ReporterName</span>
                            }
                            else
                            {

                                <span class="text-muted">–</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(c.AssigneeName))
                            {
                                <span class="small"><i class="fas fa-user-cog me-1 text-muted"></i>@c.AssigneeName</span>
                            }
                            else
                            {

                                <span class="badge bg-light text-danger border border-danger">Unassigned</span>
                            }
                        </td>
                        <td class="small text-muted">@c.CreatedAt.ToString("dd/MM/yy")</td>
                        <td class="small text-muted">
                            @if (c.ResolvedAt.HasValue)
                            {
                                <span class="text-success">@c.ResolvedAt.Value.ToString("dd/MM/yy")</span>
                            }
                            else
                            {

                                <span class="text-muted">–</span>
                            }
                        </td>
                        <td>
                            <a href="/Complaint/Details/@c.ComplaintId"
                               class="btn btn-info btn-sm" title="View Details">
                                <i class="fas fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="text-muted small mt-2">
        Showing @Model.Count() complaint(s)
        @{
            var open = Model.Count(c => c.Status != "Closed" && c.Status != "Resolved");
        }
        @if (open > 0)
        {
         < span class= "text-danger fw-semibold" > @open open </ span >
        }
</div>
}
