@model eAdmin.Web.ViewModels.ScheduleCreateViewModel
@{ ViewData["Title"] = "Edit Schedule"; }
<h4><i class="fas fa-calendar-edit me-2 text-warning"></i>Edit Schedule</h4>
<div class="card shadow-sm"><div class="card-body">
<form asp-action="Edit" method="post">@Html.AntiForgeryToken()
<input type="hidden" asp-for="ScheduleId"/>
<div class="row g-3">
<div class="col-md-6"><label asp-for="LabId" class="form-label fw-semibold">Lab</label><select asp-for="LabId" asp-items="ViewBag.Labs" class="form-select"></select></div>
<div class="col-md-6"><label asp-for="InstructorId" class="form-label fw-semibold">Instructor</label><select asp-for="InstructorId" asp-items="ViewBag.Instructors" class="form-select"></select></div>
<div class="col-md-6"><label asp-for="SubjectName" class="form-label fw-semibold">Subject</label><input asp-for="SubjectName" class="form-control"/></div>
<div class="col-md-2"><label asp-for="DayOfWeek" class="form-label fw-semibold">Day</label>
<select asp-for="DayOfWeek" class="form-select"><option value="1">Mon</option><option value="2">Tue</option><option value="3">Wed</option><option value="4">Thu</option><option value="5">Fri</option><option value="6">Sat</option><option value="7">Sun</option></select></div>
<div class="col-md-2"><label asp-for="StartTime" class="form-label fw-semibold">Start</label><input asp-for="StartTime" type="time" class="form-control"/></div>
<div class="col-md-2"><label asp-for="EndTime" class="form-label fw-semibold">End</label><input asp-for="EndTime" type="time" class="form-control"/></div>
<div class="col-md-4"><label asp-for="EffectiveFrom" class="form-label fw-semibold">Effective From</label><input asp-for="EffectiveFrom" type="date" class="form-control"/></div>
<div class="col-md-4"><label asp-for="EffectiveTo" class="form-label fw-semibold">Effective To</label><input asp-for="EffectiveTo" type="date" class="form-control"/></div>
</div>
<div class="d-flex gap-2 justify-content-end mt-3"><a href="/Schedule/Index" class="btn btn-secondary">Cancel</a><button class="btn btn-warning">Save & Notify</button></div>
</form></div></div>
