@model IEnumerable<eAdmin.Web.Controllers.ScheduleListItem>
@using System.Text.Json
@{
    ViewData["Title"] = "Lab Schedules";
    var role = User.FindFirst("Role")?.Value ?? "";
    var isAdmin = role == "Admin";

    var scheduleList = Model?.Select(s => new
    {
        id = s.ScheduleId,
        subject = s.SubjectName,
        day = s.DayOfWeek,
        start = s.StartTime.ToString(@"hh\:mm"),
        end = s.EndTime.ToString(@"hh\:mm"),
        lab = s.LabName,
        instructor = s.InstructorName,
        from = s.EffectiveFrom.ToString("yyyy-MM-dd"),
        to = s.EffectiveTo.HasValue ? s.EffectiveTo.Value.ToString("yyyy-MM-dd") : "",
        active = s.IsActive
    }) ?? Enumerable.Empty<object>();

    var schedulesJson = JsonSerializer.Serialize(scheduleList);
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<style>
    .cal-wrap * {
        box-sizing: border-box
    }

    .cal-wrap {
        font-family: -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
        border: 1px solid #dadce0;
        border-radius: 8px;
        overflow: hidden;
        background: #fff;
        color: #202124
    }

    /* Toolbar */
    .cal-toolbar {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        border-bottom: 1px solid #dadce0;
        background: #fff;
        flex-wrap: wrap
    }

        .cal-toolbar h2 {
            font-size: 18px;
            font-weight: 400;
            flex: 1;
            color: #202124;
            margin: 0;
            min-width: 160px
        }

    .cal-btn {
        padding: 6px 14px;
        border-radius: 4px;
        border: 1px solid #dadce0;
        background: #fff;
        cursor: pointer;
        font-size: 13px;
        color: #3c4043;
        transition: background .15s
    }

        .cal-btn:hover {
            background: #f1f3f4
        }

    .cal-btn-primary {
        background: #1a73e8;
        color: #fff;
        border-color: #1a73e8
    }

        .cal-btn-primary:hover {
            background: #1765cc
        }

    .cal-btn-icon {
        padding: 6px 10px;
        border-radius: 4px;
        border: 1px solid #dadce0;
        background: #fff;
        cursor: pointer;
        font-size: 16px;
        color: #3c4043
    }

        .cal-btn-icon:hover {
            background: #f1f3f4
        }

    /* Week / Month view toggle */
    .cal-view-toggle {
        display: flex;
        border: 1px solid #dadce0;
        border-radius: 4px;
        overflow: hidden
    }

        .cal-view-toggle button {
            padding: 6px 14px;
            border: none;
            background: #fff;
            cursor: pointer;
            font-size: 13px;
            color: #3c4043;
            transition: background .15s
        }

            .cal-view-toggle button:not(:last-child) {
                border-right: 1px solid #dadce0
            }

            .cal-view-toggle button.active {
                background: #1a73e8;
                color: #fff
            }

            .cal-view-toggle button:not(.active):hover {
                background: #f1f3f4
            }

    /* Instructor color legend */
    .cal-legend {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items: center
    }

    .cal-leg-item {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        color: #5f6368
    }

    .cal-leg-dot {
        width: 10px;
        height: 10px;
        border-radius: 2px;
        flex-shrink: 0
    }

    /* Schedule filter panel */
    .cal-filter-panel {
        border-bottom: 1px solid #dadce0;
        background: #fff;
    }

    .cal-filter-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 16px;
        border-bottom: 1px solid #f1f3f4;
        flex-wrap: wrap;
        min-height: 42px;
    }

    .cal-filter-header-label {
        font-size: 11px;
        font-weight: 500;
        color: #9aa0a6;
        text-transform: uppercase;
        letter-spacing: .6px;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .cal-filter-chips {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        flex: 1;
        align-items: center;
    }

    .cal-filter-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: #e8f0fe;
        color: #1a73e8;
        border-radius: 20px;
        padding: 3px 10px 3px 8px;
        font-size: 11px;
        font-weight: 500;
        border: 1px solid #c5d9f8;
        animation: chipIn .15s ease;
    }

    @@keyframes chipIn {
        from {
            opacity: 0;
            transform: scale(.85)
        }

        to {
            opacity: 1;
            transform: scale(1)
        }
    }

    .cal-chip-icon {
        font-size: 11px;
        opacity: .7
    }

    .cal-chip-x {
        cursor: pointer;
        font-size: 14px;
        line-height: 1;
        opacity: .6;
        padding: 0 0 0 2px;
        transition: opacity .15s;
    }

        .cal-chip-x:hover {
            opacity: 1;
            color: #c5221f
        }

    .cal-filter-clear-all {
        font-size: 11px;
        color: #5f6368;
        cursor: pointer;
        white-space: nowrap;
        padding: 3px 10px;
        border-radius: 20px;
        border: 1px solid #dadce0;
        background: none;
        transition: all .15s;
        display: none;
    }

        .cal-filter-clear-all:hover {
            background: #fce8e6;
            color: #c5221f;
            border-color: #f5c6c6;
        }

    .cal-filter-body {
        display: flex;
        align-items: flex-end;
        gap: 10px;
        padding: 10px 16px;
        flex-wrap: wrap;
    }

    .cal-filter-group {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

        .cal-filter-group label {
            font-size: 11px;
            font-weight: 500;
            color: #9aa0a6;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

    .cal-filter-input-wrap {
        position: relative;
        display: flex;
        align-items: center;
    }

        .cal-filter-input-wrap svg {
            position: absolute;
            left: 8px;
            pointer-events: none;
            flex-shrink: 0;
        }

    .cal-filter-input {
        height: 34px;
        border: 1px solid #dadce0;
        border-radius: 6px;
        font-size: 13px;
        color: #202124;
        background: #f8f9fa;
        padding: 0 10px;
        transition: border-color .15s, background .15s, box-shadow .15s;
        outline: none;
    }

        .cal-filter-input.has-icon {
            padding-left: 30px;
        }

        .cal-filter-input:focus {
            border-color: #1a73e8;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(26,115,232,.12);
        }

        .cal-filter-input:hover:not(:focus) {
            border-color: #bdc1c6;
            background: #fff;
        }

    input[type=date].cal-filter-input {
        width: 148px;
    }

    .cal-date-sep {
        font-size: 13px;
        color: #9aa0a6;
        padding-bottom: 2px;
        flex-shrink: 0;
    }

    /* Instructor autocomplete dropdown */
    .cal-suggest-wrap {
        position: relative;
    }

    .cal-suggest-box {
        position: absolute;
        top: calc(100% + 2px);
        left: 0;
        right: 0;
        background: #fff;
        border: 1px solid #dadce0;
        border-radius: 6px;
        box-shadow: 0 4px 12px rgba(0,0,0,.12);
        z-index: 200;
        max-height: 180px;
        overflow-y: auto;
        display: none;
    }

        .cal-suggest-box.open {
            display: block;
        }

    .cal-suggest-item {
        padding: 8px 10px 8px 30px;
        font-size: 13px;
        color: #202124;
        cursor: pointer;
        transition: background .1s;
        position: relative;
    }

        .cal-suggest-item:hover {
            background: #f1f3f4;
        }

        .cal-suggest-item mark {
            background: none;
            color: #1a73e8;
            font-weight: 600;
        }

        .cal-suggest-item::before {
            content: "👤";
            position: absolute;
            left: 8px;
            font-size: 11px;
            top: 50%;
            transform: translateY(-50%);
        }

    /* Filtered schedule count stats */
    .cal-filter-stat {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 16px;
        border-top: 1px solid #f1f3f4;
        background: #f8f9fa;
        flex-wrap: wrap;
    }

    .cal-stat-label {
        font-size: 11px;
        color: #9aa0a6;
    }

    .cal-stat-item {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        color: #5f6368;
    }

    .cal-stat-dot {
        width: 8px;
        height: 8px;
        border-radius: 2px;
        flex-shrink: 0;
    }

    .cal-stat-sep {
        color: #dadce0;
        font-size: 14px;
    }

    /* Week grid */
    .cal-grid-outer {
        display: flex;
        overflow: auto;
        max-height: 640px
    }

    .cal-time-col {
        width: 54px;
        flex-shrink: 0;
        padding-top: 41px;
        border-right: 1px solid #dadce0
    }

    .cal-time-slot {
        height: 48px;
        display: flex;
        align-items: flex-start;
        justify-content: flex-end;
        padding-right: 8px;
        padding-top: 2px
    }

        .cal-time-slot span {
            font-size: 10px;
            color: #70757a
        }

    .cal-days-area {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 0
    }

    .cal-day-headers {
        display: grid;
        grid-template-columns: repeat(6,1fr);
        border-bottom: 1px solid #dadce0;
        position: sticky;
        top: 0;
        background: #fff;
        z-index: 10
    }

    .cal-day-hdr {
        text-align: center;
        padding: 8px 4px;
        border-left: 1px solid #dadce0
    }

    .cal-day-name {
        font-size: 11px;
        color: #70757a;
        text-transform: uppercase;
        letter-spacing: .6px
    }

    .cal-day-num {
        font-size: 13px;
        font-weight: 400;
        color: #202124
    }

        .cal-day-num.today {
            background: #1a73e8;
            color: #fff;
            border-radius: 50%;
            width: 26px;
            height: 26px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 500
        }

    .cal-time-grid {
        display: grid;
        grid-template-columns: repeat(6,1fr);
        position: relative
    }

    .cal-day-col {
        border-left: 1px solid #dadce0;
        position: relative
    }

    .cal-hour-line {
        height: 48px;
        border-bottom: 1px solid #f1f3f4
    }

    /* Schedule event block */
    .cal-event {
        position: absolute;
        left: 2px;
        right: 2px;
        border-radius: 4px;
        padding: 3px 6px;
        cursor: pointer;
        overflow: hidden;
        transition: filter .15s;
        z-index: 5
    }

        .cal-event:hover {
            filter: brightness(.92);
            z-index: 6
        }

    .cal-event-title {
        font-size: 11px;
        font-weight: 500;
        line-height: 1.3;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis
    }

    .cal-event-instructor {
        font-size: 10px;
        line-height: 1.3;
        opacity: .9;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-style: italic
    }

    .cal-event-detail {
        font-size: 10px;
        line-height: 1.4;
        opacity: .85
    }

    .cal-event.inactive {
        opacity: .42
    }

    .cal-event-badge {
        display: inline-block;
        font-size: 9px;
        border-radius: 2px;
        padding: 0 3px;
        margin-left: 3px;
        vertical-align: middle;
        background: rgba(255,255,255,.25);
        line-height: 14px
    }

    /* Month grid */
    .cal-month-wrap {
        padding: 0
    }

    .cal-month-header {
        display: grid;
        grid-template-columns: repeat(6,1fr);
        border-bottom: 1px solid #dadce0;
        background: #fff;
    }

    .cal-month-day-name {
        text-align: center;
        padding: 8px 4px;
        font-size: 11px;
        font-weight: 500;
        color: #9aa0a6;
        text-transform: uppercase;
        letter-spacing: .6px;
        border-left: 1px solid #dadce0
    }

    .cal-month-grid {
        display: grid;
        grid-template-columns: repeat(6,1fr);
        overflow: auto;
        max-height: 640px
    }

    .cal-month-cell {
        min-height: 112px;
        border-left: 1px solid #f1f3f4;
        border-bottom: 1px solid #f1f3f4;
        padding: 5px 5px 4px;
        position: relative;
        transition: background .15s;
    }

        .cal-month-cell.other-month {
            background: #fafafa;
        }

        .cal-month-cell.today-cell {
            background: rgba(26,115,232,.04);
        }

    .cal-month-cell-num {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        font-size: 12px;
        font-weight: 400;
        color: #5f6368;
        margin-bottom: 3px;
    }

    .cal-month-cell.other-month .cal-month-cell-num {
        color: #bdc1c6;
    }

    .cal-month-cell-num.today {
        background: #1a73e8;
        color: #fff;
        font-weight: 500;
    }

    .cal-month-events {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .cal-month-event {
        display: flex;
        align-items: center;
        gap: 4px;
        border-radius: 3px;
        padding: 2px 5px;
        font-size: 10px;
        font-weight: 500;
        line-height: 16px;
        cursor: pointer;
        overflow: hidden;
        transition: filter .15s;
    }

        .cal-month-event:hover {
            filter: brightness(.9)
        }

        .cal-month-event.inactive {
            opacity: .45;
        }

    .cal-month-ev-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: rgba(255,255,255,.55);
        flex-shrink: 0;
    }

    .cal-month-ev-text {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        flex: 1;
    }

    .cal-month-ev-time {
        font-size: 9px;
        opacity: .8;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .cal-month-more {
        font-size: 10px;
        color: #1a73e8;
        cursor: pointer;
        padding: 1px 4px;
        margin-top: 1px;
        border-radius: 3px;
        font-weight: 500;
        transition: background .15s;
        display: inline-block;
    }

        .cal-month-more:hover {
            background: rgba(26,115,232,.08);
        }

    .cal-month-empty {
        font-size: 10px;
        color: #dadce0;
        text-align: center;
        padding-top: 6px;
    }

    /* Day schedule popup (month view) */
    .cal-day-popup-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.32);
        z-index: 1100;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .cal-day-popup {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 8px 28px rgba(0,0,0,.22);
        padding: 16px;
        width: 300px;
        max-width: 94vw;
        max-height: 80vh;
        overflow-y: auto;
    }

    .cal-day-popup-title {
        font-size: 13px;
        font-weight: 500;
        color: #202124;
        margin-bottom: 10px;
        padding-bottom: 8px;
        border-bottom: 1px solid #f1f3f4;
    }

    .cal-day-popup-ev {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 8px 4px;
        border-bottom: 1px solid #f8f9fa;
        cursor: pointer;
        border-radius: 4px;
        transition: background .12s;
    }

        .cal-day-popup-ev:last-of-type {
            border-bottom: none;
        }

        .cal-day-popup-ev:hover {
            background: #f8f9fa;
        }

    .cal-day-popup-color {
        width: 10px;
        height: 10px;
        border-radius: 2px;
        flex-shrink: 0;
        margin-top: 3px;
    }

    .cal-day-popup-info {
        flex: 1;
    }

    .cal-day-popup-name {
        font-size: 13px;
        font-weight: 500;
        color: #202124;
        line-height: 1.3;
    }

    .cal-day-popup-meta {
        font-size: 11px;
        color: #5f6368;
        margin-top: 2px;
        line-height: 1.4;
    }

    .cal-day-popup-badge {
        font-size: 10px;
        padding: 1px 6px;
        border-radius: 10px;
        font-weight: 500;
        flex-shrink: 0;
    }

    .cal-day-popup-close {
        display: block;
        width: 100%;
        margin-top: 12px;
        padding: 7px;
        border-radius: 6px;
        border: 1px solid #dadce0;
        background: none;
        font-size: 13px;
        cursor: pointer;
        color: #5f6368;
        transition: background .15s;
    }

        .cal-day-popup-close:hover {
            background: #f1f3f4;
        }

    /* Create / edit schedule modal */
    .cal-modal-bg {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.4);
        z-index: 1050;
        align-items: center;
        justify-content: center
    }

        .cal-modal-bg.show {
            display: flex
        }

    .cal-modal {
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 8px 28px rgba(0,0,0,.28);
        padding: 24px;
        width: 520px;
        max-width: 95vw;
        position: relative
    }

        .cal-modal h3 {
            font-size: 16px;
            font-weight: 400;
            color: #202124;
            margin: 0 0 18px
        }

    .cal-modal-close {
        position: absolute;
        top: 14px;
        right: 16px;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 20px;
        color: #5f6368;
        line-height: 1;
        padding: 2px
    }

        .cal-modal-close:hover {
            color: #202124
        }

    .cal-form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 12px
    }

    .cal-form-group {
        display: flex;
        flex-direction: column;
        gap: 4px
    }

        .cal-form-group label {
            font-size: 11px;
            font-weight: 500;
            color: #5f6368;
            text-transform: uppercase;
            letter-spacing: .5px
        }

        .cal-form-group input, .cal-form-group select {
            height: 36px;
            border: 1px solid #dadce0;
            border-radius: 4px;
            padding: 0 10px;
            font-size: 13px;
            color: #202124;
            background: #fff;
            outline: none
        }

            .cal-form-group input:focus, .cal-form-group select:focus {
                border-color: #1a73e8;
                box-shadow: 0 0 0 2px rgba(26,115,232,.2)
            }

    /* Time slot selector cards */
    .cal-slot-label {
        font-size: 11px;
        font-weight: 500;
        color: #5f6368;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: 8px
    }

    .cal-slot-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 14px
    }

    .cal-slot-card {
        border: 1.5px solid #dadce0;
        border-radius: 8px;
        padding: 10px 14px;
        cursor: pointer;
        text-align: center;
        transition: border-color .15s, background .15s;
        user-select: none
    }

        .cal-slot-card:hover {
            border-color: #1a73e8;
            background: #f0f6ff
        }

        .cal-slot-card.selected {
            border-color: #1a73e8;
            background: #e8f0fe
        }

    .cal-slot-time {
        font-size: 14px;
        font-weight: 600;
        color: #202124;
        line-height: 1.3
    }

    .cal-slot-name {
        font-size: 11px;
        color: #5f6368;
        margin-top: 2px
    }

    .cal-date-hint {
        font-size: 11px;
        color: #1a73e8;
        margin-top: 2px;
        min-height: 16px
    }

    .cal-modal-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 20px;
        padding-top: 16px;
        border-top: 1px solid #dadce0
    }

    .cal-btn-danger {
        background: #fce8e6;
        color: #c5221f;
        border: 1px solid #f5c6c6;
        padding: 7px 14px;
        border-radius: 4px;
        cursor: pointer;
        font-size: 13px
    }

        .cal-btn-danger:hover {
            background: #fad2cf
        }

    /* Schedule conflict warning */
    .cal-conflict {
        background: #fef7e0;
        border: 1px solid #fbbc04;
        border-radius: 4px;
        padding: 8px 12px;
        font-size: 12px;
        color: #7a5900;
        margin-bottom: 12px;
        display: none
    }

    /* Schedule effective date info */
    .cal-effective-info {
        background: #e8f0fe;
        border: 1px solid #c5d9f8;
        border-radius: 4px;
        padding: 7px 12px;
        font-size: 12px;
        color: #174ea6;
        margin-bottom: 12px;
        display: none
    }

    /* Quick toast notification */
    .cal-toast {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        background: #202124;
        color: #fff;
        padding: 10px 20px;
        border-radius: 4px;
        font-size: 13px;
        z-index: 2000;
        animation: calToastIn .25s ease
    }

    @@keyframes calToastIn {
        from {
            opacity: 0;
            transform: translateX(-50%) translateY(8px)
        }

        to {
            opacity: 1;
            transform: translateX(-50%) translateY(0)
        }
    }

    /* No available time slot message */
    .cal-no-slot-msg {
        display: none;
        font-size: 12px;
        color: #c5221f;
        background: #fce8e6;
        border: 1px solid #f5c6c6;
        border-radius: 4px;
        padding: 7px 12px;
        margin-bottom: 10px;
    }
</style>

<div class="cal-wrap">
    <!-- Toolbar: week/month navigation, view toggle, legend, add button -->
    <div class="cal-toolbar">
        <button class="cal-btn-icon" onclick="calNavWeek(-1)">&#8249;</button>
        <button class="cal-btn" onclick="calGoToday()">Today</button>
        <button class="cal-btn-icon" onclick="calNavWeek(1)">&#8250;</button>
        <h2 id="cal-week-label"></h2>

        <div class="cal-view-toggle">
            <button id="btn-view-week" class="active" onclick="calSetView('week')">Week</button>
            <button id="btn-view-month" onclick="calSetView('month')">Month</button>
        </div>

        <div class="cal-legend" id="cal-legend"></div>
        @if (isAdmin)
        {
            <button class="cal-btn cal-btn-primary" onclick="calOpenModal(null)">+ Add Schedule</button>
        }
    </div>

    <!-- Filter panel: by date range and instructor -->
    <div class="cal-filter-panel">
        <div class="cal-filter-header" id="cal-filter-header">
            <span class="cal-filter-header-label">Filter</span>
            <div class="cal-filter-chips" id="cal-filter-chips">
                <span style="font-size:11px;color:#bdc1c6;font-style:italic">No filters applied</span>
            </div>
            <button class="cal-filter-clear-all" id="cal-filter-clear-all" onclick="calClearFilter()">&#215; Clear all</button>
        </div>

        <div class="cal-filter-body">
            <div class="cal-filter-group">
                <label>From</label>
                <div class="cal-filter-input-wrap">
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                        <rect x="1" y="3" width="14" height="12" rx="2" stroke="#9aa0a6" stroke-width="1.2" />
                        <path d="M5 1v3M11 1v3M1 7h14" stroke="#9aa0a6" stroke-width="1.2" stroke-linecap="round" />
                    </svg>
                    <input type="date" id="cal-filter-from" class="cal-filter-input has-icon" onchange="calApplyFilter()" />
                </div>
            </div>
            <span class="cal-date-sep" style="padding-bottom:6px">&#8594;</span>
            <div class="cal-filter-group">
                <label>To</label>
                <div class="cal-filter-input-wrap">
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                        <rect x="1" y="3" width="14" height="12" rx="2" stroke="#9aa0a6" stroke-width="1.2" />
                        <path d="M5 1v3M11 1v3M1 7h14" stroke="#9aa0a6" stroke-width="1.2" stroke-linecap="round" />
                    </svg>
                    <input type="date" id="cal-filter-to" class="cal-filter-input has-icon" onchange="calApplyFilter()" />
                </div>
            </div>

            <div class="cal-filter-group">
                <label>Instructor</label>
                <div class="cal-suggest-wrap">
                    <div class="cal-filter-input-wrap">
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                            <circle cx="6.5" cy="6.5" r="4.5" stroke="#9aa0a6" stroke-width="1.2" />
                            <path d="M10 10l3.5 3.5" stroke="#9aa0a6" stroke-width="1.2" stroke-linecap="round" />
                        </svg>
                        <input type="text" id="cal-filter-instructor"
                               class="cal-filter-input has-icon"
                               placeholder="Search instructor..."
                               oninput="calSearchInstructor(this.value)"
                               onfocus="calShowSuggestions()"
                               autocomplete="off"
                               style="width:180px" />
                    </div>
                    <div class="cal-suggest-box" id="cal-suggest-box"></div>
                </div>
            </div>
        </div>

        <div class="cal-filter-stat" id="cal-filter-stat"></div>
    </div>

    <!-- Week view -->
    <div id="cal-view-week">
        <div class="cal-grid-outer">
            <div class="cal-time-col" id="cal-time-col"></div>
            <div class="cal-days-area">
                <div class="cal-day-headers" id="cal-day-headers"></div>
                <div class="cal-time-grid" id="cal-time-grid"></div>
            </div>
        </div>
    </div>

    <!-- Month view -->
    <div id="cal-view-month" style="display:none">
        <div class="cal-month-wrap">
            <div class="cal-month-header" id="cal-month-header"></div>
            <div class="cal-month-grid" id="cal-month-grid"></div>
        </div>
    </div>
</div>

<!-- Day schedule popup (dynamically rendered) -->
<div id="cal-day-popup-container"></div>

@if (isAdmin)
{
    <!-- Create / edit schedule modal -->
    <div class="cal-modal-bg" id="cal-modal-bg">
        <div class="cal-modal">
            <button class="cal-modal-close" onclick="calCloseModal()">&#215;</button>
            <h3 id="cal-modal-title">Add Schedule</h3>

            <div class="cal-conflict" id="cal-conflict">
                &#9888; Conflict: Lab or instructor already has a schedule in this time slot.
            </div>
            <div class="cal-effective-info" id="cal-effective-info"></div>

            <div class="cal-form-row" style="grid-template-columns:1fr">
                <div class="cal-form-group">
                    <label>Subject Name</label>
                    <input id="cal-f-subject" placeholder="e.g. Introduction to Programming" />
                </div>
            </div>

            <div class="cal-form-row">
                <div class="cal-form-group">
                    <label>Lab</label>
                    <select id="cal-f-lab" asp-items="ViewBag.Labs">
                        <option value="">-- Select Lab --</option>
                    </select>
                </div>
                <div class="cal-form-group">
                    <label>Instructor</label>
                    <select id="cal-f-instructor" asp-items="ViewBag.Instructors">
                        <option value="">-- Select Instructor --</option>
                    </select>
                </div>
            </div>

            <div class="cal-form-row">
                <div class="cal-form-group">
                    <label>Day of Week</label>
                    <select id="cal-f-day" onchange="calSyncDayToDate()">
                        <option value="0">📅 All (Mon → Sat)</option>
                        <option value="1">Monday</option>
                        <option value="2">Tuesday</option>
                        <option value="3">Wednesday</option>
                        <option value="4">Thursday</option>
                        <option value="5">Friday</option>
                        <option value="6">Saturday</option>
                    </select>
                    <div class="cal-date-hint" id="cal-day-hint"></div>
                </div>
                <div class="cal-form-group">
                    <label>Effective From</label>
                    <input id="cal-f-from" type="date" onchange="calSyncDateToDay('from')" />
                    <div class="cal-date-hint" id="cal-from-hint"></div>
                </div>
            </div>

            <div class="cal-form-row" style="grid-template-columns:1fr">
                <div class="cal-form-group">
                    <label>Effective To <small style="text-transform:none;font-weight:400">(optional)</small></label>
                    <input id="cal-f-to" type="date" onchange="calSyncDateToDay('to')" />
                    <div class="cal-date-hint" id="cal-to-hint"></div>
                </div>
            </div>

            <div class="cal-slot-label">Time Slot</div>

            <div class="cal-no-slot-msg" id="cal-no-slot-msg">
                ⏰ No available time slots for today. Please select another date.
            </div>

            <div class="cal-slot-grid" id="cal-slot-grid">
                <div class="cal-slot-card" data-start="07:00" data-end="09:00" onclick="calSelectSlot(this)">
                    <div class="cal-slot-time">07:00 – 09:00</div>
                    <div class="cal-slot-name">Morning</div>
                </div>
                <div class="cal-slot-card" data-start="09:00" data-end="11:00" onclick="calSelectSlot(this)">
                    <div class="cal-slot-time">09:00 – 11:00</div>
                    <div class="cal-slot-name">Late Morning</div>
                </div>
                <div class="cal-slot-card" data-start="13:00" data-end="15:00" onclick="calSelectSlot(this)">
                    <div class="cal-slot-time">13:00 – 15:00</div>
                    <div class="cal-slot-name">Afternoon</div>
                </div>
                <div class="cal-slot-card" data-start="15:00" data-end="17:00" onclick="calSelectSlot(this)">
                    <div class="cal-slot-time">15:00 – 17:00</div>
                    <div class="cal-slot-name">Late Afternoon</div>
                </div>
                <div class="cal-slot-card" data-start="17:00" data-end="19:00" onclick="calSelectSlot(this)">
                    <div class="cal-slot-time">17:00 – 19:00</div>
                    <div class="cal-slot-name">Evening</div>
                </div>
            </div>
            <input type="hidden" id="cal-f-start" value="07:00" />
            <input type="hidden" id="cal-f-end" value="09:00" />

            <div class="cal-modal-footer">
                <div>
                    <button class="cal-btn-danger" id="cal-btn-deactivate" style="display:none" onclick="calDeactivate()">
                        &#128683; Cancel Schedule &amp; Notify
                    </button>
                </div>
                <div style="display:flex;gap:8px">
                    <button class="cal-btn" onclick="calCloseModal()">Close</button>
                    <button class="cal-btn cal-btn-primary" onclick="calSave()">Save &amp; Notify</button>
                </div>
            </div>
        </div>
    </div>

    <form id="cal-csrf-form" style="display:none">
        @Html.AntiForgeryToken()
    </form>
}

@section Scripts {
    <script>
        (function () {
            var CAL_SCHEDULES = @Html.Raw(schedulesJson);
            var CAL_IS_ADMIN  = @(isAdmin ? "true" : "false");
            if (!Array.isArray(CAL_SCHEDULES)) CAL_SCHEDULES = [];

            var HOUR_START = 6, HOUR_END = 21;
            var DAYS_SHORT = ['Mon','Tue','Wed','Thu','Fri','Sat'];
            var DAY_NAMES  = ['','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
            var COLORS = [
                {bg:'#1a73e8',fg:'#fff'},{bg:'#0b8043',fg:'#fff'},
                {bg:'#c0392b',fg:'#fff'},{bg:'#7b1fa2',fg:'#fff'},
                {bg:'#e65100',fg:'#fff'},{bg:'#00796b',fg:'#fff'},
                {bg:'#6d4c41',fg:'#fff'},{bg:'#558b2f',fg:'#fff'},
            ];

            var weekOffset  = 0;
            var editingId   = null;
            var calView     = 'week';
            var monthOffset = 0;
            var filterFrom       = '';
            var filterTo         = '';
            var filterInstructor = '';

            // Date and time utilities
            function timeToMin(t) { var p=t.split(':'); return +p[0]*60+ +p[1]; }
            function minToY(m)    { return ((m-HOUR_START*60)/60)*48; }
            function pad2(n)      { return n<10?'0'+n:String(n); }
            function fmtDate(d)   { return pad2(d.getDate())+'/'+pad2(d.getMonth()+1)+'/'+d.getFullYear(); }
            function fmtShort(s)  { var d=isoToDate(s); return pad2(d.getDate())+'/'+pad2(d.getMonth()+1); }
            function isoToDate(s) { var p=s.split('-'); return new Date(+p[0],+p[1]-1,+p[2]); }
            function dateToIso(d) { return d.getFullYear()+'-'+pad2(d.getMonth()+1)+'-'+pad2(d.getDate()); }

            // Get Monday of the week at the given offset
            function getMonday(offset) {
                var now=new Date(), day=now.getDay();
                var mon=new Date(now);
                mon.setDate(now.getDate()-day+(day===0?-6:1)+offset*7);
                mon.setHours(0,0,0,0);
                return mon;
            }

            // Retrieve CSRF token from hidden form
            function getCsrf() {
                var el=document.querySelector('#cal-csrf-form input[name="__RequestVerificationToken"]');
                return el?el.value:'';
            }

            // Get unique instructor list from schedule data
            function getInstructors() {
                var seen={}, list=[];
                CAL_SCHEDULES.forEach(function(s){ if(!seen[s.instructor]){seen[s.instructor]=true;list.push(s.instructor);} });
                return list;
            }

            // Assign a consistent color to each instructor by order of appearance
            function getColor(name) {
                var list=getInstructors(), idx=list.indexOf(name);
                return COLORS[idx<0?0:idx%COLORS.length];
            }

            // Hide past time slots when the selected date is today
            function calFilterSlotsByDate() {
                var fromVal  = document.getElementById('cal-f-from').value;
                var todayIso = dateToIso(new Date());
                var isToday  = (fromVal === todayIso);

                var now          = new Date();
                var currentTotal = now.getHours() * 60 + now.getMinutes();

                var anyVisible = false;
                document.querySelectorAll('.cal-slot-card').forEach(function(card) {
                    var parts         = card.dataset.start.split(':');
                    var slotStartMins = parseInt(parts[0]) * 60 + parseInt(parts[1]);
                    var isPast        = isToday && slotStartMins <= currentTotal;

                    card.style.display = isPast ? 'none' : '';
                    if (isPast && card.classList.contains('selected')) {
                        card.classList.remove('selected');
                        document.getElementById('cal-f-start').value = '';
                        document.getElementById('cal-f-end').value   = '';
                    }
                    if (!isPast) anyVisible = true;
                });

                var noSlotEl = document.getElementById('cal-no-slot-msg');
                if (noSlotEl) noSlotEl.style.display = anyVisible ? 'none' : 'block';

                // Auto-select the first visible slot if none is currently selected
                var selected = document.querySelector('.cal-slot-card.selected');
                if (!selected) {
                    var firstVisible = Array.from(document.querySelectorAll('.cal-slot-card'))
                        .find(function(c) { return c.style.display !== 'none'; });
                    if (firstVisible) {
                        firstVisible.classList.add('selected');
                        document.getElementById('cal-f-start').value = firstVisible.dataset.start;
                        document.getElementById('cal-f-end').value   = firstVisible.dataset.end;
                    }
                }
            }

            // Check whether a schedule matches the current filter
            function scheduleVisible(s) {
                if (filterFrom || filterTo) {
                    var rangeStart = filterFrom ? isoToDate(filterFrom) : null;
                    var rangeEnd   = filterTo   ? isoToDate(filterTo)   : null;
                    var effFrom = s.from ? s.from : '0000-01-01';
                    var effTo   = s.to   ? s.to   : '9999-12-31';
                    if (rangeEnd   && dateToIso(rangeEnd)   < effFrom) return false;
                    if (rangeStart && dateToIso(rangeStart) > effTo)   return false;
                    var scanStart = new Date(Math.max(
                        rangeStart ? rangeStart.getTime() : isoToDate(effFrom).getTime(),
                        isoToDate(effFrom).getTime()
                    ));
                    var scanEnd = new Date(Math.min(
                        rangeEnd ? rangeEnd.getTime() : isoToDate(effTo).getTime(),
                        isoToDate(effTo).getTime()
                    ));
                    var found = false;
                    var cur = new Date(scanStart);
                    for (var limit = 0; limit < 400 && cur <= scanEnd; limit++) {
                        var jsDay = cur.getDay();
                        var dow = jsDay === 0 ? 7 : jsDay;
                        if (dow === s.day) { found = true; break; }
                        cur.setDate(cur.getDate() + 1);
                    }
                    if (!found) return false;
                }
                if (filterInstructor) {
                    if (s.instructor.toLowerCase().indexOf(filterInstructor) === -1) return false;
                }
                return true;
            }

            // Apply date filter when user changes input
            window.calApplyFilter = function() {
                filterFrom = document.getElementById('cal-filter-from').value;
                filterTo   = document.getElementById('cal-filter-to').value;
                renderFilterChips();
                calRender();
            };

            // Clear all active filters
            window.calClearFilter = function() {
                filterFrom = filterTo = filterInstructor = '';
                document.getElementById('cal-filter-from').value       = '';
                document.getElementById('cal-filter-to').value         = '';
                document.getElementById('cal-filter-instructor').value = '';
                document.getElementById('cal-suggest-box').classList.remove('open');
                renderFilterChips();
                calRender();
            };

            // Remove a single filter chip
            window.calClearFilterChip = function(type) {
                if (type==='from') { filterFrom=''; document.getElementById('cal-filter-from').value=''; }
                if (type==='to')   { filterTo='';   document.getElementById('cal-filter-to').value=''; }
                if (type==='ins')  { filterInstructor=''; document.getElementById('cal-filter-instructor').value=''; }
                renderFilterChips();
                calRender();
            };

            // Search instructors and show autocomplete dropdown
            window.calSearchInstructor = function(val) {
                filterInstructor = val.trim().toLowerCase();
                var box = document.getElementById('cal-suggest-box');
                if (!val.trim()) { box.classList.remove('open'); box.innerHTML=''; renderFilterChips(); calRender(); return; }
                var allNames = [], seen = {};
                CAL_SCHEDULES.forEach(function(s){ if(!seen[s.instructor]){seen[s.instructor]=true;allNames.push(s.instructor);} });
                var matches = allNames.filter(function(n){ return n.toLowerCase().indexOf(filterInstructor)!==-1; });
                if (!matches.length) { box.classList.remove('open'); box.innerHTML=''; }
                else {
                    var escaped = val.trim().replace(/[.*+?^${}()|[\]\\]/g,'\\$&');
                    box.innerHTML = matches.map(function(n){
                        var hi = n.replace(new RegExp('('+escaped+')','gi'),'<mark>$1</mark>');
                        return '<div class="cal-suggest-item" onclick="calSelectInstructor(\''+n.replace(/'/g,"\\'")+'\')">' + hi + '</div>';
                    }).join('');
                    box.classList.add('open');
                }
                renderFilterChips();
                calRender();
            };

            // Re-open dropdown when the search input is focused
            window.calShowSuggestions = function() {
                var val = document.getElementById('cal-filter-instructor').value;
                if (val.trim()) calSearchInstructor(val);
            };

            // Select an instructor from the autocomplete dropdown
            window.calSelectInstructor = function(name) {
                document.getElementById('cal-filter-instructor').value = name;
                filterInstructor = name.toLowerCase();
                document.getElementById('cal-suggest-box').classList.remove('open');
                renderFilterChips();
                calRender();
            };

            // Close dropdown when clicking outside
            document.addEventListener('click', function(e) {
                if (!e.target.closest('.cal-suggest-wrap')) {
                    var b = document.getElementById('cal-suggest-box');
                    if (b) b.classList.remove('open');
                }
            });

            // Update filter chips and visible schedule count stats
            function renderFilterChips() {
                var chipsEl  = document.getElementById('cal-filter-chips');
                var clearBtn = document.getElementById('cal-filter-clear-all');
                var statEl   = document.getElementById('cal-filter-stat');
                var chips    = [], hasFilter = false;
                if (filterFrom) { hasFilter=true; chips.push('<span class="cal-filter-chip"><span class="cal-chip-icon">&#128197;</span>From '+fmtShort(filterFrom)+'<span class="cal-chip-x" onclick="calClearFilterChip(\'from\')">&#215;</span></span>'); }
                if (filterTo)   { hasFilter=true; chips.push('<span class="cal-filter-chip"><span class="cal-chip-icon">&#128197;</span>To '+fmtShort(filterTo)+'<span class="cal-chip-x" onclick="calClearFilterChip(\'to\')">&#215;</span></span>'); }
                if (filterInstructor) {
                    var displayName = document.getElementById('cal-filter-instructor').value || filterInstructor;
                    hasFilter=true;
                    chips.push('<span class="cal-filter-chip"><span class="cal-chip-icon">&#128100;</span>'+displayName+'<span class="cal-chip-x" onclick="calClearFilterChip(\'ins\')">&#215;</span></span>');
                }
                chipsEl.innerHTML = hasFilter ? chips.join('') : '<span style="font-size:11px;color:#bdc1c6;font-style:italic">No filters applied</span>';
                clearBtn.style.display = hasFilter ? 'inline-block' : 'none';
                var visible = CAL_SCHEDULES.filter(scheduleVisible);
                var byIns = {};
                visible.forEach(function(s){ if(!byIns[s.instructor]) byIns[s.instructor]=0; byIns[s.instructor]++; });
                var entries = Object.entries ? Object.entries(byIns) : Object.keys(byIns).map(function(k){return[k,byIns[k]];});
                var statHTML = '<span class="cal-stat-label">'+visible.length+' schedules shown</span>';
                if (entries.length) {
                    statHTML += '<span class="cal-stat-sep">·</span>';
                    statHTML += entries.map(function(e){ var c=getColor(e[0]).bg; var short=e[0].split(' ').slice(-1)[0]; return '<span class="cal-stat-item"><span class="cal-stat-dot" style="background:'+c+'"></span>'+short+': '+e[1]+'</span>'; }).join('<span class="cal-stat-sep">·</span>');
                }
                statEl.innerHTML = statHTML;
            }

            // Switch between week and month view
            window.calSetView = function(v) {
                calView = v;
                document.getElementById('btn-view-week').classList.toggle('active',  v==='week');
                document.getElementById('btn-view-month').classList.toggle('active', v==='month');
                document.getElementById('cal-view-week').style.display  = v==='week'  ? '' : 'none';
                document.getElementById('cal-view-month').style.display = v==='month' ? '' : 'none';
                calRender();
            };

            // Navigate week/month and jump to today
            window.calNavWeek = function(d) { if (calView==='month') monthOffset+=d; else weekOffset+=d; calRender(); };
            window.calGoToday = function() { weekOffset=0; monthOffset=0; calRender(); };

            function calRender() { renderLegend(); if (calView==='week') renderWeek(); else renderMonth(); }

            // Render instructor color legend on toolbar
            function renderLegend() {
                var lg = document.getElementById('cal-legend'); if (!lg) return;
                var visible=CAL_SCHEDULES.filter(scheduleVisible), seen={}, list=[];
                visible.forEach(function(s){ if(!seen[s.instructor]){seen[s.instructor]=true;list.push(s.instructor);} });
                lg.innerHTML=list.map(function(name){ var c=getColor(name); var short=name.split(' ').slice(-1)[0]; return '<div class="cal-leg-item"><div class="cal-leg-dot" style="background:'+c.bg+'"></div>'+short+'</div>'; }).join('');
            }

            // Render week grid with schedule event blocks
            function renderWeek() {
                var mon=getMonday(weekOffset), sat=new Date(mon); sat.setDate(mon.getDate()+5);
                document.getElementById('cal-week-label').textContent=mon.toLocaleDateString('vi-VN',{day:'2-digit',month:'long',year:'numeric'})+' \u2013 '+sat.toLocaleDateString('vi-VN',{day:'2-digit',month:'long'});
                var tc=document.getElementById('cal-time-col'); tc.innerHTML='';
                for (var h=HOUR_START;h<HOUR_END;h++){var sl=document.createElement('div');sl.className='cal-time-slot';sl.innerHTML='<span>'+h+':00</span>';tc.appendChild(sl);}
                var dh=document.getElementById('cal-day-headers');
                dh.innerHTML=DAYS_SHORT.map(function(d,i){var date=new Date(mon);date.setDate(mon.getDate()+i);var isToday=new Date().toDateString()===date.toDateString();var n=isToday?'<span class="cal-day-num today">'+date.getDate()+'</span>':'<span class="cal-day-num">'+date.getDate()+'</span>';return '<div class="cal-day-hdr"><div class="cal-day-name">'+d+'</div>'+n+'</div>';}).join('');
                var grid=document.getElementById('cal-time-grid');grid.innerHTML='';var cols=[];
                for (var i=0;i<6;i++){var col=document.createElement('div');col.className='cal-day-col';for(var h2=HOUR_START;h2<HOUR_END;h2++){var hl=document.createElement('div');hl.className='cal-hour-line';col.appendChild(hl);}grid.appendChild(col);cols.push(col);}
                var monTime=mon.getTime(),satTime=sat.getTime()+86399999;
                CAL_SCHEDULES.forEach(function(s){
                    if (!scheduleVisible(s)) return;
                    var ci=s.day-1; if(ci<0||ci>5) return;
                    var colDate=new Date(mon);colDate.setDate(mon.getDate()+ci);var colIso=dateToIso(colDate);
                    if (filterFrom&&colIso<filterFrom) return;
                    if (filterTo&&colIso>filterTo) return;
                    var fromTime=s.from?new Date(s.from).getTime():0,toTime=s.to?new Date(s.to).getTime():Infinity;
                    if (fromTime>satTime||toTime<monTime) return;
                    var top=minToY(timeToMin(s.start)),height=Math.max(minToY(timeToMin(s.end))-top-2,22);
                    var c=getColor(s.instructor),ev=document.createElement('div');
                    ev.className='cal-event'+(s.active?'':' inactive');
                    ev.style.cssText='top:'+top+'px;height:'+height+'px;background:'+c.bg+';color:'+c.fg;
                    var badge='',today=new Date();today.setHours(0,0,0,0);
                    var fromD=new Date(s.from),toD=s.to?new Date(s.to):null;
                    if(fromD>today) badge='<span class="cal-event-badge">Upcoming</span>';
                    else if(toD&&toD<today) badge='<span class="cal-event-badge">Expired</span>';
                    ev.innerHTML='<div class="cal-event-title">'+s.subject+badge+(s.active?'':' \u2715')+'</div>'+'<div class="cal-event-instructor">'+s.instructor+'</div>'+'<div class="cal-event-detail">'+s.start+'\u2013'+s.end+' \xb7 '+s.lab+'</div>';
                    if(CAL_IS_ADMIN)(function(sid){ev.onclick=function(){calOpenModal(sid);};})(s.id);
                    cols[ci].appendChild(ev);
                });
            }

            // Render month grid with day cells and condensed schedule list
            function renderMonth() {
                var now=new Date(),year=now.getFullYear(),month=now.getMonth()+monthOffset;
                while(month>11){month-=12;year++;}while(month<0){month+=12;year--;}
                document.getElementById('cal-week-label').textContent='Month '+(month+1)+', '+year;
                var mh=document.getElementById('cal-month-header');
                mh.innerHTML=DAYS_SHORT.map(function(d){return '<div class="cal-month-day-name">'+d+'</div>';}).join('');
                var firstDay=new Date(year,month,1),todayStr=dateToIso(new Date()),startDow=firstDay.getDay(),startMon=new Date(firstDay);
                startMon.setDate(firstDay.getDate()-(startDow===0?6:startDow-1));
                var cells=[],cursor=new Date(startMon);
                for(var w=0;w<6;w++){var weekHasDays=false;for(var d=0;d<6;d++){var inMonth=(cursor.getMonth()===month&&cursor.getFullYear()===year);if(inMonth)weekHasDays=true;cells.push({date:new Date(cursor),inMonth:inMonth});cursor.setDate(cursor.getDate()+1);}if(!weekHasDays&&w>0)break;}
                var grid=document.getElementById('cal-month-grid');grid.innerHTML='';
                cells.forEach(function(cell){
                    var isoDate=dateToIso(cell.date),dayOfWeek=cell.date.getDay(),dow=dayOfWeek===0?7:dayOfWeek;
                    var daySchedules=CAL_SCHEDULES.filter(function(s){
                        if(!scheduleVisible(s))return false;if(s.day!==dow)return false;
                        if(filterFrom&&isoDate<filterFrom)return false;if(filterTo&&isoDate>filterTo)return false;
                        var fromOk=!s.from||s.from<=isoDate,toOk=!s.to||s.to>=isoDate;return fromOk&&toOk;
                    });
                    var cellEl=document.createElement('div');
                    cellEl.className='cal-month-cell'+(cell.inMonth?'':' other-month')+(isoDate===todayStr?' today-cell':'');
                    var numEl=document.createElement('div');numEl.className='cal-month-cell-num'+(isoDate===todayStr?' today':'');numEl.textContent=cell.date.getDate();cellEl.appendChild(numEl);
                    var evWrap=document.createElement('div');evWrap.className='cal-month-events';
                    var MAX_SHOW=3;
                    daySchedules.slice(0,MAX_SHOW).forEach(function(s){
                        var c=getColor(s.instructor),evEl=document.createElement('div');
                        evEl.className='cal-month-event'+(s.active?'':' inactive');evEl.style.cssText='background:'+c.bg+';color:'+c.fg;
                        var shortName=s.instructor.split(' ').slice(-1)[0];
                        evEl.innerHTML='<span class="cal-month-ev-dot"></span><span class="cal-month-ev-text">'+s.subject+' · '+shortName+'</span><span class="cal-month-ev-time">'+s.start+'</span>';
                        evEl.title=s.subject+' — '+s.instructor+' ('+s.start+'–'+s.end+', '+s.lab+')';
                        (function(scheds,dateObj){evEl.onclick=function(e){e.stopPropagation();calShowDayPopup(isoDate,scheds,dateObj);};})(daySchedules,cell.date);
                        evWrap.appendChild(evEl);
                    });
                    if(daySchedules.length>MAX_SHOW){var moreEl=document.createElement('div');moreEl.className='cal-month-more';moreEl.textContent='+'+(daySchedules.length-MAX_SHOW)+' more';(function(scheds,dateObj){moreEl.onclick=function(){calShowDayPopup(isoDate,scheds,dateObj);};})(daySchedules,cell.date);evWrap.appendChild(moreEl);}
                    if(!daySchedules.length&&cell.inMonth){var emptyEl=document.createElement('div');emptyEl.className='cal-month-empty';emptyEl.textContent='–';evWrap.appendChild(emptyEl);}
                    cellEl.appendChild(evWrap);grid.appendChild(cellEl);
                });
            }

            // Show popup listing all schedules for a specific day
            window.calShowDayPopup = function(isoDate, schedules, dateObj) {
                var label=dateObj.toLocaleDateString('vi-VN',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
                var today=new Date();today.setHours(0,0,0,0);
                var evRows=schedules.map(function(s){
                    var c=getColor(s.instructor),fromD=new Date(s.from),toD=s.to?new Date(s.to):null;
                    var badgeText='',badgeStyle='';
                    if(!s.active){badgeText='Cancelled';badgeStyle='background:#fce8e6;color:#c5221f';}
                    else if(fromD>today){badgeText='Upcoming';badgeStyle='background:#fef7e0;color:#7a5900';}
                    else if(toD&&toD<today){badgeText='Expired';badgeStyle='background:#f1f3f4;color:#5f6368';}
                    var badge=badgeText?'<span class="cal-day-popup-badge" style="'+badgeStyle+'">'+badgeText+'</span>':'';
                    var clickAttr=CAL_IS_ADMIN?' onclick="calClosePopupAndEdit('+s.id+')" style="cursor:pointer"':'';
                    return '<div class="cal-day-popup-ev"'+clickAttr+'><div class="cal-day-popup-color" style="background:'+c.bg+'"></div><div class="cal-day-popup-info"><div class="cal-day-popup-name">'+s.subject+'</div><div class="cal-day-popup-meta">'+s.start+' – '+s.end+' &nbsp;·&nbsp; '+s.lab+'</div><div class="cal-day-popup-meta">'+s.instructor+'</div></div>'+badge+'</div>';
                }).join('');
                document.getElementById('cal-day-popup-container').innerHTML='<div class="cal-day-popup-overlay" onclick="if(event.target===this)calCloseDayPopup()"><div class="cal-day-popup"><div class="cal-day-popup-title">'+label+'</div>'+evRows+'<button class="cal-day-popup-close" onclick="calCloseDayPopup()">Close</button></div></div>';
            };

            window.calCloseDayPopup = function() { document.getElementById('cal-day-popup-container').innerHTML=''; };

            // Close day popup then open the edit modal
            window.calClosePopupAndEdit = function(id) { calCloseDayPopup(); calOpenModal(id); };

            // Select a time slot card on the modal
            window.calSelectSlot = function(card) {
                document.querySelectorAll('.cal-slot-card').forEach(function(c){ c.classList.remove('selected'); });
                card.classList.add('selected');
                document.getElementById('cal-f-start').value = card.dataset.start;
                document.getElementById('cal-f-end').value   = card.dataset.end;
            };

            // Mark the slot matching start/end time as selected; fall back to first visible slot if no match
            function calSetSlotByTime(start, end) {
                var cards=document.querySelectorAll('.cal-slot-card');
                var matched=false;
                cards.forEach(function(c){ c.classList.remove('selected'); });
                cards.forEach(function(c){ if(c.dataset.start===start&&c.dataset.end===end){c.classList.add('selected');matched=true;} });
                if (!matched&&cards.length>0) {
                    var firstVisible = Array.from(cards).find(function(c){ return c.style.display !== 'none'; });
                    if (firstVisible) firstVisible.classList.add('selected');
                }
                document.getElementById('cal-f-start').value=matched?start:(document.querySelector('.cal-slot-card.selected')||{dataset:{start:''}}).dataset.start||'';
                document.getElementById('cal-f-end').value=matched?end:(document.querySelector('.cal-slot-card.selected')||{dataset:{end:''}}).dataset.end||'';
            }

            // Calculate the nearest date matching the selected day of week
            function nearestDateForDay(dayTarget) {
                var today=new Date();today.setHours(0,0,0,0);
                var diff=(dayTarget-today.getDay()+7)%7;
                var result=new Date(today);result.setDate(today.getDate()+diff);return result;
            }

            // On day-of-week change: update effective-from date and re-filter slots
            window.calSyncDayToDate = function() {
                var day=+document.getElementById('cal-f-day').value;
                var hintEl=document.getElementById('cal-day-hint');
                if(day===0){hintEl.textContent='Applies to all Mon → Sat';updateEffectiveInfo();calFilterSlotsByDate();return;}
                var d=nearestDateForDay(day);
                document.getElementById('cal-f-from').value=dateToIso(d);
                hintEl.textContent=DAY_NAMES[day];
                updateFromHint();updateEffectiveInfo();
                calFilterSlotsByDate();
            };

            // On effective date change: sync day-of-week selector and re-filter slots
            window.calSyncDateToDay = function(which) {
                if(which==='from'){
                    var val=document.getElementById('cal-f-from').value;if(!val)return;
                    var d=isoToDate(val),jsD=d.getDay(),cur=+document.getElementById('cal-f-day').value;
                    if(cur!==0&&jsD>=1&&jsD<=6){document.getElementById('cal-f-day').value=jsD;document.getElementById('cal-day-hint').textContent=DAY_NAMES[jsD];}
                    updateFromHint();
                    calFilterSlotsByDate();
                }
                if(which==='to') updateToHint();
                updateEffectiveInfo();
            };

            // Update from / to effective date hint labels
            function updateFromHint() {
                var val=document.getElementById('cal-f-from').value,el=document.getElementById('cal-from-hint');
                if(!val){el.textContent='';return;}var d=isoToDate(val);el.textContent='From '+fmtDate(d)+' ('+(DAY_NAMES[d.getDay()]||'Sun')+')';
            }
            function updateToHint() {
                var val=document.getElementById('cal-f-to').value,el=document.getElementById('cal-to-hint');
                if(!val){el.textContent='(no end date)';return;}var d=isoToDate(val);el.textContent='To '+fmtDate(d)+' ('+(DAY_NAMES[d.getDay()]||'Sun')+')';
            }

            // Update the effective-date status banner
            function updateEffectiveInfo() {
                var infoEl=document.getElementById('cal-effective-info');if(!infoEl)return;
                var fromVal=document.getElementById('cal-f-from').value,toVal=document.getElementById('cal-f-to').value;
                var today=new Date();today.setHours(0,0,0,0);
                if(!fromVal){infoEl.style.display='none';return;}
                var from=isoToDate(fromVal),to=toVal?isoToDate(toVal):null,msg='';
                if(from>today) msg='⏳ Not yet effective — starts on '+fmtDate(from);
                else if(to&&to<today) msg='⛔ Expired on '+fmtDate(to);
                else if(to) msg='✅ Active until '+fmtDate(to);
                else msg='✅ Active (no end date)';
                infoEl.textContent=msg;infoEl.style.display='block';
            }

            // Open modal: create new (id=null) or edit existing schedule by id
            window.calOpenModal = function(id) {
                if(!CAL_IS_ADMIN) return;
                editingId=id;
                var s=id?CAL_SCHEDULES.find(function(x){return x.id===id;}):null;
                document.getElementById('cal-modal-title').textContent=id?'Edit Schedule':'Add Schedule';
                document.getElementById('cal-f-subject').value=s?s.subject:'';
                document.getElementById('cal-f-day').value=s?s.day:1;
                if(!s){var initDay=+document.getElementById('cal-f-day').value;document.getElementById('cal-f-from').value=dateToIso(nearestDateForDay(initDay));}
                else{document.getElementById('cal-f-from').value=s.from;}
                document.getElementById('cal-f-to').value=s?s.to:'';
                if(s){
                    var ls=document.getElementById('cal-f-lab'),ins=document.getElementById('cal-f-instructor');
                    for(var i=0;i<ls.options.length;i++) if(ls.options[i].text===s.lab){ls.selectedIndex=i;break;}
                    for(var j=0;j<ins.options.length;j++) if(ins.options[j].text===s.instructor){ins.selectedIndex=j;break;}
                }
                calFilterSlotsByDate();
                calSetSlotByTime(s?s.start:'07:00',s?s.end:'09:00');
                var day=+document.getElementById('cal-f-day').value;
                document.getElementById('cal-day-hint').textContent=day===0?'Applies to all Mon → Sat':(DAY_NAMES[day]||'');
                document.getElementById('cal-f-from').min=dateToIso(new Date());
                updateFromHint();updateToHint();updateEffectiveInfo();
                document.getElementById('cal-conflict').style.display='none';
                var bd=document.getElementById('cal-btn-deactivate');
                if(bd) bd.style.display=(id&&s&&s.active)?'block':'none';
                document.getElementById('cal-modal-bg').classList.add('show');
            };

            window.calCloseModal = function() { document.getElementById('cal-modal-bg').classList.remove('show'); editingId=null; };

            // Validate, check conflicts, and submit the create/edit form
            window.calSave = function() {
                var subj=document.getElementById('cal-f-subject').value.trim();
                var start=document.getElementById('cal-f-start').value;
                var end=document.getElementById('cal-f-end').value;
                var day=+document.getElementById('cal-f-day').value;
                var ls=document.getElementById('cal-f-lab'),is=document.getElementById('cal-f-instructor');
                var from=document.getElementById('cal-f-from').value,to=document.getElementById('cal-f-to').value;
                if(!subj){alert('Please enter the subject name');return;}
                if(!ls.value){alert('Please select a Lab');return;}
                if(!is.value){alert('Please select an Instructor');return;}
                if(!start||!end){alert('Please select a time slot');return;}
                if(!from){alert('Please select an effective date');return;}
                if(to&&to<from){alert('End date must be after the effective start date');return;}
                var daysToSubmit=(day===0)?[1,2,3,4,5,6]:[day];
                var conflict=CAL_SCHEDULES.some(function(s){
                    if(editingId&&s.id===editingId)return false;
                    if(!s.active||daysToSubmit.indexOf(s.day)===-1)return false;
                    var ss=timeToMin(s.start),se=timeToMin(s.end),ns=timeToMin(start),ne=timeToMin(end);
                    return ns<se&&ne>ss&&(s.lab===ls.options[ls.selectedIndex].text||s.instructor===is.options[is.selectedIndex].text);
                });
                if(conflict){document.getElementById('cal-conflict').style.display='block';return;}
                if(day===0&&editingId){alert('The All-days option is only available when creating. Please edit each day individually.');return;}

                // Submit days sequentially; last day uses a standard form submit to trigger redirect
                function submitNext(i){
                    if(i>=daysToSubmit.length)return;
                    var d=daysToSubmit[i];
                    var form=document.createElement('form');form.method='post';
                    var fields={ScheduleId:(editingId&&daysToSubmit.length===1)?editingId:0,SubjectName:subj,LabId:ls.value,InstructorId:is.value,DayOfWeek:d,StartTime:start,EndTime:end,EffectiveFrom:from,EffectiveTo:to,__RequestVerificationToken:getCsrf()};
                    Object.keys(fields).forEach(function(k){var inp=document.createElement('input');inp.type='hidden';inp.name=k;inp.value=fields[k];form.appendChild(inp);});
                    document.body.appendChild(form);
                    if(i<daysToSubmit.length-1){
                        form.action='/Schedule/CreateSilent';var data=new FormData(form);
                        fetch('/Schedule/CreateSilent',{method:'POST',body:data}).then(function(r){if(!r.ok)r.text().then(function(t){alert('Error on day '+d+': '+t);});else submitNext(i+1);}).catch(function(){alert('Connection error while creating schedule for day '+d);});
                    } else {form.action=(editingId&&daysToSubmit.length===1)?'/Schedule/Edit':'/Schedule/Create';form.submit();}
                }
                submitNext(0);
            };

            // Deactivate schedule: update UI immediately, call API silently
            window.calDeactivate = function() {
                if(!editingId||!confirm('Are you sure you want to cancel this schedule?'))return;
                var sid=editingId,csrf=getCsrf();
                var idx=CAL_SCHEDULES.findIndex(function(x){return x.id===sid;});
                if(idx!==-1)CAL_SCHEDULES.splice(idx,1);
                calCloseModal();calRender();renderFilterChips();
                var toast=document.createElement('div');toast.className='cal-toast';toast.textContent='✅ Schedule cancelled';document.body.appendChild(toast);
                setTimeout(function(){if(toast.parentNode)toast.parentNode.removeChild(toast);},2500);
                var formData=new FormData();formData.append('__RequestVerificationToken',csrf);
                fetch('/Schedule/Deactivate/'+sid,{method:'POST',body:formData}).catch(function(){});
            };

            document.addEventListener('DOMContentLoaded', function(){
                var bg=document.getElementById('cal-modal-bg');
                if(bg) bg.addEventListener('click',function(e){if(e.target===this)calCloseModal();});
                renderFilterChips();
                calRender();
            });
        })();
    </script>
}
