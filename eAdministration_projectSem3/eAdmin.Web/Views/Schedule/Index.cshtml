@model IEnumerable<eAdmin.Web.Controllers.ScheduleListItem>
@{
    ViewData["Title"] = "Lab Schedules";
    var role = User.FindFirst("Role")?.Value ?? "";
    dynamic schedules = ViewBag.Schedules ?? Model;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="fas fa-calendar-alt me-2 text-primary"></i>Lab Schedules</h4>
    @if(role == "Admin"){
    <a href="/Schedule/Create" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>New Schedule</a>}
</div>
@if(TempData["Success"] != null){<div class="alert alert-success">@TempData["Success"]</div>}
@if(TempData["Error"] != null){<div class="alert alert-danger">@TempData["Error"]</div>}

<div class="table-responsive">
<table class="table table-hover table-bordered align-middle">
<thead class="table-dark">
    <tr><th>ID</th><th>Subject</th><th>Lab</th><th>Instructor</th><th>Day</th><th>Time</th><th>Effective From</th><th>Effective To</th><th>Status</th>@if(role=="Admin"){<th>Actions</th>}</tr>
</thead>
<tbody>
@foreach(var s in Model){
    string[] days = {"","Mon","Tue","Wed","Thu","Fri","Sat","Sun"};
    <tr>
    <td>@s.ScheduleId</td>
    <td><strong>@s.SubjectName</strong></td>
    <td>@s.LabName</td>
    <td>@s.InstructorName</td>
    <td>@(s.DayOfWeek >= 1 && s.DayOfWeek <= 7 ? days[s.DayOfWeek] : s.DayOfWeek.ToString())</td>
    <td>@s.StartTime.ToString(@"hh\:mm") – @s.EndTime.ToString(@"hh\:mm")</td>
    <td>@s.EffectiveFrom.ToString("dd/MM/yyyy")</td>
    <td>@(s.EffectiveTo.HasValue ? s.EffectiveTo.Value.ToString("dd/MM/yyyy") : "–")</td>
    <td><span class="badge @(s.IsActive ? "bg-success" : "bg-danger")">@(s.IsActive ? "Active" : "Inactive")</span></td>
    @if(role == "Admin"){
    <td>
        <a href="/Schedule/Edit/@s.ScheduleId" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
        <form method="post" action="/Schedule/Deactivate/@s.ScheduleId" class="d-inline">@Html.AntiForgeryToken()
        <button class="btn btn-danger btn-sm" onclick="return confirm('Deactivate this schedule?')"><i class="fas fa-ban"></i></button></form>
    </td>}
    </tr>}
</tbody>
</table>
</div>
