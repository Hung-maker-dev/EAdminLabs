@{ ViewData["Title"] = "System Overview Report"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="fas fa-tachometer-alt me-2 text-primary"></i>System Overview Report</h4>
    <button onclick="window.print()" class="btn btn-outline-secondary btn-sm"><i class="fas fa-print me-1"></i>Print</button>
</div>
<div class="row g-3">
<div class="col-md-4"><div class="card border-primary shadow-sm"><div class="card-header bg-primary text-white fw-bold"><i class="fas fa-building me-2"></i>Labs</div>
<div class="card-body"><div class="d-flex justify-content-between"><span>Total Labs</span><strong>@ViewBag.TotalLabs</strong></div><hr class="my-2"/>
<div class="d-flex justify-content-between"><span>Active Labs</span><strong class="text-success">@ViewBag.ActiveLabs</strong></div>
<div class="d-flex justify-content-between"><span>Active Schedules</span><strong>@ViewBag.TotalSchedules</strong></div></div></div></div>

<div class="col-md-4"><div class="card border-success shadow-sm"><div class="card-header bg-success text-white fw-bold"><i class="fas fa-desktop me-2"></i>Equipment</div>
<div class="card-body"><div class="d-flex justify-content-between"><span>Total Equipment</span><strong>@ViewBag.TotalEquipment</strong></div><hr class="my-2"/>
<div class="d-flex justify-content-between"><span>Good Condition</span><strong class="text-success">@ViewBag.EquipmentGood</strong></div>
<div class="d-flex justify-content-between"><span>Poor / Out of Service</span><strong class="text-danger">@ViewBag.EquipmentPoor</strong></div></div></div></div>

<div class="col-md-4"><div class="card border-danger shadow-sm"><div class="card-header bg-danger text-white fw-bold"><i class="fas fa-exclamation-triangle me-2"></i>Complaints</div>
<div class="card-body"><div class="d-flex justify-content-between"><span>Total</span><strong>@ViewBag.TotalComplaints</strong></div><hr class="my-2"/>
<div class="d-flex justify-content-between"><span>Open (unresolved)</span><strong class="text-danger">@ViewBag.OpenComplaints</strong></div></div></div></div>

<div class="col-md-4"><div class="card border-secondary shadow-sm"><div class="card-header bg-secondary text-white fw-bold"><i class="fas fa-users me-2"></i>Users</div>
<div class="card-body"><div class="d-flex justify-content-between"><span>Total Users</span><strong>@ViewBag.TotalUsers</strong></div><hr class="my-2"/>
<div class="d-flex justify-content-between"><span>Active Users</span><strong class="text-success">@ViewBag.ActiveUsers</strong></div></div></div></div>

<div class="col-md-4"><div class="card border-warning shadow-sm"><div class="card-header bg-warning fw-bold"><i class="fas fa-clock me-2"></i>Software Licenses</div>
<div class="card-body"><div class="d-flex justify-content-between"><span>Expiring ≤ 30 days</span><strong class="text-danger">@ViewBag.ExpiringSW</strong></div>
<hr class="my-2"/><a href="/Report/SoftwareExpiry" class="btn btn-sm btn-outline-warning w-100">View Full Report</a></div></div></div>
</div>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="row g-3 mt-2">
    <!-- Equipment Condition Donut -->
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header fw-bold bg-success text-white"><i class="fas fa-desktop me-2"></i>Equipment Condition</div>
            <div class="card-body"><canvas id="chartEquipOverview" height="220"></canvas></div>
        </div>
    </div>
    <!-- Complaints Status Bar -->
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header fw-bold bg-danger text-white"><i class="fas fa-exclamation-triangle me-2"></i>Complaints Status</div>
            <div class="card-body"><canvas id="chartComplaintsOverview" height="220"></canvas></div>
        </div>
    </div>
    <!-- Users & Labs Bar -->
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header fw-bold bg-primary text-white"><i class="fas fa-chart-bar me-2"></i>Labs & Users</div>
            <div class="card-body"><canvas id="chartLabsUsers" height="220"></canvas></div>
        </div>
    </div>
</div>

<script>
    // Equipment Overview Donut
    new Chart(document.getElementById('chartEquipOverview'), {
        type: 'doughnut',
        data: {
            labels: ['Good', 'Poor / Out of Service', 'Others'],
            datasets: [{
                data: [@ViewBag.EquipmentGood, @ViewBag.EquipmentPoor,
                       @ViewBag.TotalEquipment - @ViewBag.EquipmentGood - @ViewBag.EquipmentPoor],
                backgroundColor: ['#198754','#dc3545','#adb5bd']
            }]
        },
        options: { plugins: { legend: { position: 'bottom' } }, cutout: '60%' }
    });

    // Complaints Overview Bar
    new Chart(document.getElementById('chartComplaintsOverview'), {
        type: 'bar',
        data: {
            labels: ['Total', 'Open'],
            datasets: [{
                label: 'Complaints',
                data: [@ViewBag.TotalComplaints, @ViewBag.OpenComplaints],
                backgroundColor: ['#6c757d','#dc3545']
            }]
        },
        options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
    });

    // Labs & Users
    new Chart(document.getElementById('chartLabsUsers'), {
        type: 'bar',
        data: {
            labels: ['Total Labs', 'Active Labs', 'Total Users', 'Active Users'],
            datasets: [{
                label: 'Count',
                data: [@ViewBag.TotalLabs, @ViewBag.ActiveLabs, @ViewBag.TotalUsers, @ViewBag.ActiveUsers],
                backgroundColor: ['#0d6efd','#0dcaf0','#6f42c1','#20c997']
            }]
        },
        options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
    });
</script>