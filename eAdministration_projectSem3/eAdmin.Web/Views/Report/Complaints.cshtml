@model IEnumerable<eAdmin.Web.ViewModels.ComplaintListViewModel>
@{
    ViewData["Title"] = "Complaint Report";
}
<h4><i class="fas fa-chart-bar me-2 text-danger"></i>Complaint Report</h4>
<form method="get" class="row g-2 mb-3 align-items-end">

    <div class="col-md-2">
        <label class="form-label small fw-semibold">Search</label>
        <input name="keyword" value="@ViewBag.Keyword"
               placeholder="Title, user..."
               class="form-control form-control-sm" />
    </div>

    <div class="col-md-2">
        <label class="form-label small fw-semibold">From</label>
        <input name="from" type="date" value="@ViewBag.From"
               class="form-control form-control-sm" />
    </div>

    <div class="col-md-2">
        <label class="form-label small fw-semibold">To</label>
        <input name="to" type="date" value="@ViewBag.To"
               class="form-control form-control-sm" />
    </div>

    <div class="col-md-2">
        <label class="form-label small fw-semibold">Status</label>
        <select name="status" class="form-select form-select-sm">
            <option value="">All</option>
            @foreach (var s in new[] { "Pending", "Assigned", "InProgress", "Resolved", "Closed" })
            {
                <option value="@s" selected="@(ViewBag.FilterStatus == s)">@s</option>
            }
        </select>
    </div>

    <div class="col-md-2">
        <label class="form-label small fw-semibold">Lab</label>
        <select name="labId" asp-items="ViewBag.Labs"
                class="form-select form-select-sm">
            <option value="">All Labs</option>
        </select>
    </div>

    <div class="col-md-2 d-flex gap-1">
        <button class="btn btn-primary btn-sm w-50">
            <i class="fas fa-search"></i>
        </button>

        <a href="/Report/Complaints" class="btn btn-secondary btn-sm w-50">
            Reset
        </a>
    </div>

</form>

@{
    dynamic s = ViewBag.Summary;
}
<div class="row g-2 mb-3">
    <div class="col"><div class="card text-center border-secondary"><div class="card-body py-2"><div class="fs-4 fw-bold">@s.Total</div><div class="small">Total</div></div></div></div>
    <div class="col"><div class="card text-center border-warning"><div class="card-body py-2"><div class="fs-4 fw-bold text-warning">@s.Pending</div><div class="small">Pending</div></div></div></div>
    <div class="col"><div class="card text-center border-info"><div class="card-body py-2"><div class="fs-4 fw-bold text-info">@s.InProgress</div><div class="small">In Progress</div></div></div></div>
    <div class="col"><div class="card text-center border-success"><div class="card-body py-2"><div class="fs-4 fw-bold text-success">@s.Resolved</div><div class="small">Resolved</div></div></div></div>
    <div class="col"><div class="card text-center border-dark"><div class="card-body py-2"><div class="fs-4 fw-bold">@s.Closed</div><div class="small">Closed</div></div></div></div>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-sm table-hover">
        <thead class="table-dark"><tr><th>#</th><th>Title</th><th>Type</th><th>Lab</th><th>Priority</th><th>Status</th><th>Reporter</th><th>Assignee</th><th>Created</th><th>Resolved</th></tr></thead>
        <tbody>
            @foreach (var c in Model)
            {
                var badge = c.Priority == "Critical" ? "bg-danger" : c.Priority == "High" ? "bg-warning text-dark" : c.Priority == "Medium" ? "bg-info" : "bg-secondary";
                var sbadge = c.Status == "Resolved" ? "bg-success" : c.Status == "Closed" ? "bg-dark" : c.Status == "InProgress" ? "bg-warning text-dark" : c.Status == "Assigned" ? "bg-info" : "bg-secondary";
                <tr>
                    <td>@c.ComplaintId</td>
                    <td>@c.Title</td>
                    <td>@c.TypeName</td>
                    <td>@c.LabName</td>
                    <td><span class="badge @badge">@c.Priority</span></td>
                    <td><span class="badge @sbadge">@c.Status</span></td>
                    <td>@c.ReporterName</td>
                    <td>@(c.AssigneeName ?? "-")</td>
                    <td class="small">@c.CreatedAt.ToString("dd/MM/yy")</td>
                    <td class="small">@(c.ResolvedAt?.ToString("dd/MM/yy") ?? "-")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="row g-3 mb-3">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header fw-bold"><i class="fas fa-chart-pie me-2"></i>Complaints by Status</div>
            <div class="card-body"><canvas id="chartComplaintStatus" height="200"></canvas></div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header fw-bold"><i class="fas fa-chart-bar me-2"></i>Complaints by Priority</div>
            <div class="card-body"><canvas id="chartComplaintPriority" height="200"></canvas></div>
        </div>
    </div>
</div>

@{
    var byPriority = Model.GroupBy(c => c.Priority).Select(g => new { Label = g.Key ?? "Unknown", Count = g.Count() }).ToList();
    var byLab = Model.GroupBy(c => c.LabName).Select(g => new { Label = g.Key, Count = g.Count() }).ToList();
}

<script>
    // Status Donut
    new Chart(document.getElementById('chartComplaintStatus'), {
        type: 'doughnut',
        data: {
            labels: ['Pending', 'In Progress', 'Resolved', 'Closed'],
            datasets: [{
                data: [@s.Pending, @s.InProgress, @s.Resolved, @s.Closed],
                backgroundColor: ['#ffc107','#0dcaf0','#198754','#343a40']
            }]
        },
        options: { plugins: { legend: { position: 'bottom' } }, cutout: '55%' }
    });

    // Priority Bar
    new Chart(document.getElementById('chartComplaintPriority'), {
        type: 'bar',
        data: {
            labels: [@Html.Raw(string.Join(",", byPriority.Select(p => $"'{p.Label}'")))],
            datasets: [{
                label: 'Complaints',
                data: [@string.Join(",", byPriority.Select(p => p.Count))],
                backgroundColor: ['#dc3545','#ffc107','#0dcaf0','#6c757d']
            }]
        },
        options: {
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
        }
    });
</script>