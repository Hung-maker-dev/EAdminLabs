@model eAdmin.Web.ViewModels.EquipmentViewModel
@{ ViewData["Title"] = "Add Equipment"; }
<h4><i class="fas fa-plus me-2 text-primary"></i>Add Equipment</h4>
<div class="card shadow-sm"><div class="card-body">
<form asp-action="Create" method="post">@Html.AntiForgeryToken()
<div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid?"none":"block")"></div>
<div class="row g-3">
<div class="col-md-4"><label asp-for="AssetCode" class="form-label fw-semibold">Asset Code</label><input asp-for="AssetCode" class="form-control" placeholder="e.g. PC-LAB1-001"/><span asp-validation-for="AssetCode" class="text-danger small"></span></div>
<div class="col-md-4"><label asp-for="LabId" class="form-label fw-semibold">Lab</label><select asp-for="LabId" asp-items="ViewBag.Labs" class="form-select"><option value="">-- Select Lab --</option></select></div>
<div class="col-md-4"><label asp-for="EquipmentTypeId" class="form-label fw-semibold">Type</label><select asp-for="EquipmentTypeId" asp-items="ViewBag.EquipmentTypes" class="form-select"><option value="">-- Select Type --</option></select></div>
<div class="col-md-4"><label asp-for="Model" class="form-label fw-semibold">Model</label><input asp-for="Model" class="form-control"/></div>
<div class="col-md-4"><label asp-for="SerialNumber" class="form-label fw-semibold">Serial Number</label><input asp-for="SerialNumber" class="form-control"/></div>
<div class="col-md-4"><label asp-for="Condition" class="form-label fw-semibold">Condition</label>
<select asp-for="Condition" class="form-select"><option value="Good">Good</option><option value="Fair">Fair</option><option value="Poor">Poor</option><option value="OutOfService">Out of Service</option></select></div>
<div class="col-md-4"><label asp-for="PurchaseDate" class="form-label fw-semibold">Purchase Date</label><input asp-for="PurchaseDate" type="date" class="form-control"/></div>
<div class="col-md-4"><label asp-for="WarrantyExpiry" class="form-label fw-semibold">Warranty Expiry</label><input asp-for="WarrantyExpiry" type="date" class="form-control"/></div>
<div class="col-md-12"><label asp-for="Notes" class="form-label fw-semibold">Notes</label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>
</div>
<div class="d-flex gap-2 justify-content-end mt-3"><a href="/Equipment/Index" class="btn btn-secondary">Cancel</a><button class="btn btn-primary">Add Equipment</button></div>
</form></div></div>
