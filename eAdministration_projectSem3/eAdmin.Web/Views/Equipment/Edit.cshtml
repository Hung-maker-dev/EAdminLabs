@model eAdmin.Web.ViewModels.EquipmentViewModel
@{
    ViewData["Title"] = "Edit Equipment";
}

<div class="container">
    <div class="d-flex align-items-center mb-3">
        <a href="/Equipment/Index" class="btn btn-outline-secondary btn-sm me-2">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h4 class="mb-0">
            <i class="fas fa-pencil-alt me-2 text-primary"></i>Edit Equipment
        </h4>
    </div>

    <!-- 🔥 CENTER FORM -->
    <div class="row justify-content-center mt-3 mb-4">
        <div class="col-md-6">

            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="EquipmentId" />

                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <p class="text-muted small fw-semibold text-uppercase mb-2 border-bottom pb-1">
                            Identification
                        </p>

                        <div class="mb-3">
                            <label asp-for="AssetCode" class="form-label fw-semibold"></label>
                            <input asp-for="AssetCode" class="form-control" />
                            <span asp-validation-for="AssetCode" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col">
                                <label asp-for="LabId"></label>
                                <select asp-for="LabId" asp-items="ViewBag.Labs" class="form-select"></select>
                                <span asp-validation-for="LabId" class="text-danger"></span>
                            </div>
                            <div class="col">
                                <label asp-for="EquipmentTypeId"></label>
                                <select asp-for="EquipmentTypeId" asp-items="ViewBag.EquipmentTypes" class="form-select"></select>
                                <span asp-validation-for="EquipmentTypeId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col">
                                <label asp-for="Model"></label>
                                <input asp-for="Model" class="form-control" />
                                <span asp-validation-for="Model" class="text-danger"></span>
                            </div>
                            <div class="col">
                                <label asp-for="SerialNumber"></label>
                                <input asp-for="SerialNumber" class="form-control" />
                                <span asp-validation-for="SerialNumber" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Condition"></label>
                            <select asp-for="Condition" class="form-select">
                                <option value="Good">Good</option>
                                <option value="Fair">Fair</option>
                                <option value="Poor">Poor</option>
                            </select>
                            <span asp-validation-for="Condition" class="text-danger"></span>
                        </div>

                        <p class="text-muted small fw-semibold text-uppercase mb-2 border-bottom pb-1 mt-3">
                            Purchase & Warranty
                        </p>

                        <div class="row mb-3">
                            <div class="col">
                                <label asp-for="PurchaseDate"></label>
                                <input asp-for="PurchaseDate" type="date" class="form-control" />
                                <span asp-validation-for="PurchaseDate" class="text-danger"></span>
                            </div>
                            <div class="col">
                                <label asp-for="WarrantyExpiry"></label>
                                <input asp-for="WarrantyExpiry" type="date" class="form-control" />
                                <span asp-validation-for="WarrantyExpiry" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Notes"></label>
                            <textarea asp-for="Notes" class="form-control"></textarea>
                        </div>

                        <div class="d-flex justify-content-end">
                            <a href="/Equipment/Index" class="btn btn-secondary me-2">Cancel</a>
                            <button type="submit" class="btn btn-primary">Save</button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>