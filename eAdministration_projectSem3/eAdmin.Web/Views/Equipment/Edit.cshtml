@model eAdmin.Web.ViewModels.EquipmentViewModel
@{ ViewData["Title"] = "Edit Equipment"; }
<h4><i class="fas fa-edit me-2 text-warning"></i>Edit Equipment</h4>
<div class="card shadow-sm"><div class="card-body">
<form asp-action="Edit" method="post">@Html.AntiForgeryToken()
<input type="hidden" asp-for="EquipmentId"/>
<div class="row g-3">
<div class="col-md-4"><label asp-for="AssetCode" class="form-label fw-semibold"></label><input asp-for="AssetCode" class="form-control" readonly/></div>
<div class="col-md-4"><label asp-for="LabId" class="form-label fw-semibold">Lab</label><select asp-for="LabId" asp-items="ViewBag.Labs" class="form-select"></select></div>
<div class="col-md-4"><label asp-for="EquipmentTypeId" class="form-label fw-semibold">Type</label><select asp-for="EquipmentTypeId" asp-items="ViewBag.EquipmentTypes" class="form-select"></select></div>
<div class="col-md-4"><label asp-for="Model" class="form-label fw-semibold">Model</label><input asp-for="Model" class="form-control"/></div>
<div class="col-md-4"><label asp-for="SerialNumber" class="form-label fw-semibold">Serial Number</label><input asp-for="SerialNumber" class="form-control"/></div>
<div class="col-md-4"><label asp-for="Condition" class="form-label fw-semibold">Condition</label>
<select asp-for="Condition" class="form-select"><option>Good</option><option>Fair</option><option>Poor</option><option>OutOfService</option></select></div>
<div class="col-md-4"><label asp-for="PurchaseDate" class="form-label fw-semibold">Purchase Date</label><input asp-for="PurchaseDate" type="date" class="form-control"/></div>
<div class="col-md-4"><label asp-for="WarrantyExpiry" class="form-label fw-semibold">Warranty Expiry</label><input asp-for="WarrantyExpiry" type="date" class="form-control"/></div>
<div class="col-md-12"><label asp-for="Notes" class="form-label fw-semibold">Notes</label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>
</div>
<div class="d-flex gap-2 justify-content-end mt-3"><a href="/Equipment/Index" class="btn btn-secondary">Cancel</a><button class="btn btn-warning">Save</button></div>
</form></div></div>
