@model eAdmin.Web.ViewModels.EquipmentTypeViewModel
@{
    ViewData["Title"] = "Create Equipment Type";
}

<div class="d-flex align-items-center mb-3">
    <a href="/EquipmentType/Index" class="btn btn-outline-secondary btn-sm me-2">
        <i class="fas fa-arrow-left"></i>
    </a>
    <h4 class="mb-0">
        <i class="fas fa-plus me-2 text-primary"></i>Create Equipment Type
    </h4>
</div>

<div class="card shadow-sm" style="max-width:520px">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            @* Show all errors *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <strong>Please fix the following errors:</strong>
                    <ul class="mb-0 mt-1">
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@err.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <!-- TYPE NAME -->
            <div class="mb-3">
                <label asp-for="TypeName" class="form-label fw-semibold">
                    Type Name <span class="text-danger">*</span>
                </label>

                <input asp-for="TypeName"
                       class="form-control @(ViewData.ModelState.ContainsKey("TypeName") && ViewData.ModelState["TypeName"].Errors.Count > 0 ? "is-invalid" : "")"
                       placeholder="e.g. Laptop, Projector, Printer"
                       autofocus />

                <span asp-validation-for="TypeName" class="invalid-feedback"></span>

                <div class="form-text">
                    Must be unique. Min 2 characters.
                </div>
            </div>

            <!-- DESCRIPTION -->
            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold">
                    Description <small class="text-muted">(optional)</small>
                </label>

                <textarea asp-for="Description"
                          class="form-control"
                          rows="3"
                          placeholder="Brief description..."></textarea>
            </div>

            <!-- BUTTONS -->
            <div class="d-flex gap-2 justify-content-end">
                <a href="/EquipmentType/Index" class="btn btn-secondary">
                    Cancel
                </a>

                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i>Save
                </button>
            </div>

        </form>
    </div>
</div>