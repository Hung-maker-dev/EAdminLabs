@model IEnumerable<eAdmin.Web.ViewModels.EquipmentTypeViewModel>
@{ ViewData["Title"] = "Equipment Types"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="fas fa-tags me-2 text-primary"></i>Equipment Types</h4>
    <a href="/EquipmentType/Create" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>New Type</a>
</div>
@if(TempData["Success"]!=null){<div class="alert alert-success">@TempData["Success"]</div>}
@if(TempData["Error"]!=null){<div class="alert alert-danger">@TempData["Error"]</div>}
<table class="table table-hover table-bordered">
<thead class="table-dark"><tr><th>#</th><th>Type Name</th><th>Description</th><th>Equipment Count</th><th>Actions</th></tr></thead>
<tbody>@foreach(var t in Model){<tr>
<td>@t.EquipmentTypeId</td><td><strong>@t.TypeName</strong></td><td>@t.Description</td>
<td><span class="badge bg-info">@t.EquipmentCount</span></td>
<td>
<a href="/EquipmentType/Edit/@t.EquipmentTypeId" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
<form method="post" action="/EquipmentType/Delete/@t.EquipmentTypeId" class="d-inline">@Html.AntiForgeryToken()
<button class="btn btn-danger btn-sm" onclick="return confirm('Delete?')"><i class="fas fa-trash"></i></button></form>
</td></tr>}</tbody></table>
